---
// No props — copy and href are hardcoded per D-19 (consistent across all three layout contexts)
---

<section class="cta-strip" aria-label="Contact call to action">
  <div class="cta-strip-inner">
    <h2 class="cta-strip-heading">Want to work together?</h2>
    <p class="cta-strip-body">If something resonated, I'd love to hear from you.</p>
    <a href="/contact" class="cta-strip-btn">Get in touch</a>
  </div>
</section>

<style>
  .cta-strip {
    margin: 64px 0 0;
    padding: 48px 24px;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 20%, transparent);
    text-align: center;
  }

  .cta-strip-inner {
    max-width: 32rem;
    margin: 0 auto;
  }

  .cta-strip-heading {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .cta-strip-body {
    font-size: 15px;
    color: var(--color-muted);
    margin: 0 0 24px;
    line-height: 1.6;
  }

  /* Same recipe as resume.astro .download-cta */
  .cta-strip-btn {
    display: inline-block;
    background: var(--color-accent);
    color: #ffffff;
    padding: 12px 28px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: background 120ms var(--motion-ease-out, ease-out);
  }

  .cta-strip-btn:hover {
    background: color-mix(in srgb, var(--color-accent), black 8%);
  }

  .cta-strip-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 6px;
  }
</style>
