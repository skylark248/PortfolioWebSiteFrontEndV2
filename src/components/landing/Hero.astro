---
/**
 * Hero.astro — Engineer-classic dense hero (Lee Robinson-style).
 *
 * Structure:
 *   Left  (8 cols on >=900px): eyebrow → display name → display tagline
 *                              → pitch paragraph → status pill → dual CTAs
 *   Right (4 cols, hairline border-left): mono meta column
 *                              (Role / Company / Based / Hours / Writing / Code)
 *
 * Invariants preserved from prior contract (do NOT break):
 *   - <h1 class="hero-name"> with NO animation, NO opacity/transform transition (LAND-05)
 *   - <p class="hero-tagline"> with NO animation, NO opacity/transform transition (LAND-05)
 *   - "Get in touch" link present and visible (LAND-01)
 *   - "Read my resume" link present and visible (LAND-01)
 *   - "Currently @ Morgan Stanley" text rendered via StatusPill (LAND-01)
 *
 * Cursor-track accent (D-16) — preserved; retuned to teal-on-navy via tokens.
 */

import StatusPill from "../ui/StatusPill.astro";
---

<section class="hero" aria-labelledby="hero-name">
  <div class="hero-grid">

    {/* ── Left column: identity + pitch ───────────────────────── */}
    <div class="hero-main">
      <p class="hero-eyebrow">Hi, my name is</p>

      {/* LAND-05: name is static from first paint. */}
      <h1 id="hero-name" class="hero-name">Shivansh Choudhary.</h1>

      {/* LAND-05: tagline is static from first paint. */}
      <p class="hero-tagline">I build resilient systems behind the screen.</p>

      <p class="hero-pitch">
        I'm a senior software engineer at Morgan Stanley. Before that, I built
        a Cassandra reporting tier that took report generation from
        <strong class="hero-pitch-num">3&nbsp;minutes</strong> to
        <strong class="hero-pitch-num">under&nbsp;5&nbsp;seconds</strong>
        across 10M+ records.
      </p>
      <a href="/case-studies/cassandra-reporting-database/" class="hero-pitch-cta">
        Read the case study <span class="hero-pitch-cta-arrow" aria-hidden="true">→</span>
      </a>

      <div class="hero-status-row">
        <StatusPill
          label="Currently @ Morgan Stanley"
          ariaLabel="Currently: Senior Software Engineer at Morgan Stanley"
        />
      </div>

      <div class="hero-ctas">
        <a href="/contact" class="cta-primary">
          Get in touch <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/resume" class="cta-secondary">Read my resume</a>
      </div>
    </div>

    {/* ── Right column: at-a-glance meta (mono, hairline ruled) ── */}
    <aside class="hero-meta" aria-label="At a glance">
      <dl>
        <div class="meta-row">
          <dt>Role</dt>
          <dd>Senior Software Engineer</dd>
        </div>
        <div class="meta-row">
          <dt>Company</dt>
          <dd>Morgan Stanley</dd>
        </div>
        <div class="meta-row">
          <dt>Based</dt>
          <dd>United States</dd>
        </div>
        <div class="meta-row">
          <dt>Hours</dt>
          <dd>US time zones</dd>
        </div>
        <div class="meta-row">
          <dt>Writing</dt>
          <dd><a href="/blog">/blog</a></dd>
        </div>
        <div class="meta-row">
          <dt>Code</dt>
          <dd><a href="https://github.com/skylark248" rel="me noopener noreferrer" target="_blank">github / skylark248</a></dd>
        </div>
      </dl>
    </aside>

  </div>
</section>

<style>
  /* ── Container ─────────────────────────────────────────────── */
  .hero {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 120px) 24px clamp(48px, 8vw, 96px);
    position: relative;
    --cursor-x: 30%;
    --cursor-y: 30%;
  }

  /* D-16: cursor-track ambient glow — z-index:0 keeps it behind content. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      640px circle at var(--cursor-x) var(--cursor-y),
      color-mix(in srgb, var(--color-accent) 9%, transparent),
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 48px;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
      gap: 64px;
      align-items: start;
    }
  }

  /* ── Left column ──────────────────────────────────────────── */
  .hero-main {
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-width: 0;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0;
  }

  /* LAND-05: hero-name MUST have no opacity/transform transition. */
  .hero-name {
    font-size: var(--text-display);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.022em;
    margin: 0;
    color: var(--color-ink);
  }

  /* LAND-05: hero-tagline MUST have no opacity/transform transition. */
  .hero-tagline {
    font-size: clamp(24px, 3.6vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-muted);
    margin: 0;
    max-width: 22ch;
  }

  .hero-pitch {
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-ink);
    margin: 4px 0 0;
    max-width: 56ch;
  }

  /* Highlight numbers inside the pitch paragraph so the scale jumps off the page. */
  .hero-pitch-num {
    color: var(--color-accent);
    font-weight: 700;
    white-space: nowrap;
  }

  /* Standalone case-study link beneath the pitch — mono, accent, animated arrow. */
  .hero-pitch-cta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.03em;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    padding-bottom: 2px;
    margin-top: -4px;
    transition: border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .hero-pitch-cta-arrow {
    transition: transform var(--motion-duration-base) var(--motion-ease-out);
  }
  .hero-pitch-cta:hover { border-bottom-color: var(--color-accent); }
  .hero-pitch-cta:hover .hero-pitch-cta-arrow { transform: translateX(3px); }
  @media (prefers-reduced-motion: reduce) {
    .hero-pitch-cta,
    .hero-pitch-cta-arrow { transition: none; }
    .hero-pitch-cta:hover .hero-pitch-cta-arrow { transform: none; }
  }

  .hero-status-row {
    margin-top: 4px;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 12px;
  }

  @media (max-width: 479px) {
    .hero-ctas {
      flex-direction: column;
      align-items: stretch;
    }
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0.015em;
    text-decoration: none;
    transition:
      background var(--motion-duration-base) var(--motion-ease-out),
      color var(--motion-duration-base) var(--motion-ease-out),
      border-color var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      box-shadow var(--motion-duration-base) var(--motion-ease-out);
  }

  .cta-primary {
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
  }
  .cta-primary:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--color-accent);
  }
  .cta-primary .cta-arrow {
    transition: transform var(--motion-duration-base) var(--motion-ease-out);
  }
  .cta-primary:hover .cta-arrow {
    transform: translateX(2px);
  }

  .cta-secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
  }
  .cta-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-primary,
    .cta-secondary,
    .cta-primary .cta-arrow {
      transition: none;
    }
    .cta-primary:hover {
      transform: none;
      box-shadow: none;
    }
    .cta-primary:hover .cta-arrow {
      transform: none;
    }
  }

  /* ── Right column: meta ──────────────────────────────────── */
  .hero-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
  }

  @media (min-width: 900px) {
    .hero-meta {
      border-left: 1px solid var(--color-line);
      padding-left: 32px;
      align-self: stretch;
    }
  }

  .hero-meta dl {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .meta-row {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .meta-row dt {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 11px;
    color: color-mix(in srgb, var(--color-muted) 85%, transparent);
  }
  .meta-row dd {
    margin: 0;
    color: var(--color-ink);
    overflow-wrap: anywhere;
  }
  .meta-row dd a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
    transition:
      color var(--motion-duration-base) var(--motion-ease-out),
      border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .meta-row dd a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>

{/*
  D-16: Cursor-track accent — CSS variable updates only.
  - is:inline keeps Astro from deduping across pages (without it, the listener
    fails to re-attach after a View Transition back to /).
  - Re-attaches on astro:page-load (first load + every VT nav).
  - Cleans up on astro:before-swap (no stale listeners across navs).
  - Gated: pointer:fine AND prefers-reduced-motion:no-preference.
*/}
<script is:inline>
  (function () {
    function setup() {
      const prefersNoMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const isFinePointer = window.matchMedia("(pointer: fine)").matches;
      if (prefersNoMotion || !isFinePointer) return;

      const hero = document.querySelector(".hero");
      if (!hero) return;

      let rafId = null;
      let pendingX = null;
      let pendingY = null;

      function onPointerMove(e) {
        const rect = hero.getBoundingClientRect();
        pendingX = ((e.clientX - rect.left) / rect.width * 100).toFixed(1) + "%";
        pendingY = ((e.clientY - rect.top) / rect.height * 100).toFixed(1) + "%";
        if (rafId) return;
        rafId = requestAnimationFrame(function () {
          hero.style.setProperty("--cursor-x", pendingX);
          hero.style.setProperty("--cursor-y", pendingY);
          rafId = null;
        });
      }

      hero.addEventListener("pointermove", onPointerMove);

      document.addEventListener("astro:before-swap", function cleanup() {
        hero.removeEventListener("pointermove", onPointerMove);
        if (rafId) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
        document.removeEventListener("astro:before-swap", cleanup);
      }, { once: true });
    }

    document.addEventListener("astro:page-load", setup);
  })();
</script>
