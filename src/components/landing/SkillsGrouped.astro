---
// LAND-04: skills as text-only tags grouped by category — no rating bars, no logo grid, no <meter>.
// Chips are <span>, not <a>: per RESEARCH.md Pitfall 7, this avoids 35 tabbable elements
// and drops the WCAG 2.5.5 min-height: 44px touch target (chips are non-interactive labels here).
// Engineer-classic restyle (v3): mono category labels, slimmer flat chips, tighter rhythm.
import { skills } from "../../data/skills";

interface Props {
  /** Optional mono section marker rendered before the heading (e.g. "04."). */
  number?: string;
}
const { number } = Astro.props;
---
<section class="skills-grouped" aria-labelledby="skills-heading">
  <h2 id="skills-heading" class="skills-section-heading">
    {number && <span class="skills-number" aria-hidden="true">{number}</span>}
    <span class="skills-heading-text">Stack</span>
  </h2>
  <div class="skills-grid">
    {skills.map((cat) => (
      <div class="skill-category">
        <h3 class="skill-category-name">{cat.category}</h3>
        <div class="skill-chips">
          {cat.items.map((item) => (
            <span class="tag-chip skill-chip">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-grouped {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .skills-section-heading {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    letter-spacing: -0.01em;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 16px;
  }
  .skills-number {
    font-family: var(--font-mono);
    font-size: 0.55em;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    position: relative;
    top: -0.05em;
  }
  .skills-heading-text { display: inline-block; }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 28px 32px;
  }
  .skill-category {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .skill-category-name {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }
  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
  }
  /* PATTERNS.md §SkillsGrouped: <span> chips, no 44px touch min (Pitfall 7).
     Engineer-classic restyle: monospace, flat, hairline border, no pill fill. */
  .skill-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.4;
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
    letter-spacing: 0.01em;
  }
</style>
