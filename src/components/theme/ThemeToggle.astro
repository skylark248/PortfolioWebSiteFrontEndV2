{/* class="theme-toggle" — was id="theme-toggle". Two ThemeToggle instances render
    per page (one in BaseLayout's nav, one inside HamburgerMenu's drawer). The
    prior id caused duplicate IDs in the DOM, and getElementById only attached
    the click handler to the first one — so the desktop button worked but the
    mobile drawer button did nothing, and any race on which one mounted first
    could break toggling entirely. Class + querySelectorAll handles N instances. */}
<button class="theme-toggle" type="button" aria-pressed="false" aria-label="Toggle dark theme">
  <span aria-hidden="true">🌓</span>
</button>

<script>
  function setup() {
    const btns = Array.from(document.querySelectorAll<HTMLButtonElement>(".theme-toggle"));
    if (btns.length === 0) return;

    function syncAriaPressed() {
      const isDark = document.documentElement.dataset.theme === "dark";
      for (const b of btns) {
        b.setAttribute("aria-pressed", String(isDark));
      }
    }
    syncAriaPressed();

    for (const btn of btns) {
      btn.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme;
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch (e) { /* private mode — ignore */ }
        // Sync EVERY toggle's aria-pressed so the drawer button and the nav
        // button never disagree on the active state.
        syncAriaPressed();
      });
    }
  }
  // astro:page-load fires on initial load AND after every View Transition swap,
  // ensuring listeners are always bound to the current button elements.
  document.addEventListener("astro:page-load", setup);
</script>
