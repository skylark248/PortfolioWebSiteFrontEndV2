<button id="theme-toggle" type="button" aria-pressed="false" aria-label="Toggle dark theme">
  <span aria-hidden="true">🌓</span>
</button>

<script>
  function setup() {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    // Nested function declarations don't preserve the post-early-return
    // narrowing of `btn`; assert non-null inside them.
    function syncAriaPressed() {
      const isDark = document.documentElement.dataset.theme === "dark";
      btn!.setAttribute("aria-pressed", String(isDark));
    }
    syncAriaPressed();
    btn.addEventListener("click", () => {
      const current = document.documentElement.dataset.theme;
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
      syncAriaPressed();
    });
  }
  // astro:page-load fires on initial load AND after every View Transition swap,
  // ensuring the click handler is always bound to the current button element.
  document.addEventListener("astro:page-load", setup);
</script>
