---
// src/components/mdx/Aside.astro
// Pull-quote / parallel-track MDX component (D-08, UI-SPEC "Aside").
// Visually distinct from Callout: softer border, italic body, indented, no icon/label.
// Accessibility: role="complementary" with aria-label="Aside".
// No props — content via default slot.
---

<aside
  class="mdx-aside"
  role="complementary"
  aria-label="Aside"
>
  <slot />
</aside>

<style>
  .mdx-aside {
    border-left: 2px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
    background: color-mix(in srgb, var(--color-bg) 70%, var(--color-ink) 6%);
    border-radius: 0 4px 4px 0;
    padding: 16px;
    margin: 24px 0 24px 24px; /* indent from prose left edge — parallel-track signal */
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    font-style: italic;
    color: var(--color-ink);
  }

  .mdx-aside :global(p:first-child) { margin-top: 0; }
  .mdx-aside :global(p:last-child)  { margin-bottom: 0; }
</style>
