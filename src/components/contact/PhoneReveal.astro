---
// Phone obfuscated as base64 — never render the E.164 number as a string literal
// Encoded: atob("KzkxNzQzNjA2OTc0NA==") decodes to the E.164 number on click
---
<button
  id="phone-reveal-btn"
  type="button"
  class="phone-reveal-btn"
  aria-label="Show phone number"
  data-phone="KzkxNzQzNjA2OTc0NA=="
>Show phone</button>

<script>
  function setup() {
    const btn = document.getElementById("phone-reveal-btn") as HTMLButtonElement | null;
    if (!btn) return;
    btn.addEventListener("click", function () {
      const encoded = btn.dataset.phone ?? "";
      const number = atob(encoded);
      const anchor = document.createElement("a");
      anchor.href = "tel:" + number;
      anchor.textContent = number;
      anchor.className = "phone-link";
      btn.parentNode?.replaceChild(anchor, btn);
    }, { once: true });
  }
  document.addEventListener("astro:page-load", setup);
</script>

<style>
  .phone-reveal-btn {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-accent);
    font: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .phone-reveal-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>
