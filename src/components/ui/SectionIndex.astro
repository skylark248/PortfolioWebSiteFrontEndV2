---
// src/components/ui/SectionIndex.astro
// Inline H2 table of contents for case study detail pages (D-07).
// Only rendered when the entry has >= 4 H2 headings (threshold set in CaseStudyLayout).

interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
// Only H2 headings passed from CaseStudyLayout — depth is always 2 here
---

<nav class="section-index" aria-label="Contents">
  <p class="section-index-label">Contents</p>
  <ol class="section-index-list">
    {headings.map((h, i) => (
      <li>
        <span class="section-index-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}.</span>
        <a href={`#${h.slug}`} class="section-index-link">{h.text}</a>
      </li>
    ))}
  </ol>
</nav>

<style>
  /* Engineer-classic: flat surface, hairline border, mono accent label
     + numbered entries that mirror the rail headings on landing. */
  .section-index {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 20px 24px;
    margin-bottom: 40px;
  }

  .section-index-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0 0 14px;
  }

  .section-index-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .section-index-list li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin: 0;
  }

  .section-index-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .section-index-link {
    font-size: 14px;
    color: var(--color-ink);
    text-decoration: none;
    line-height: 1.5;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }

  .section-index-link:hover {
    color: var(--color-accent);
  }
</style>
