---
// src/components/ui/MetaStrip.astro
// Flexible meta row atom used in both blog and case-study headers (D-06).
// Renders dot-separated text items (date · reading time · role · timeline) and tag chips.

import TagChip from "./TagChip.astro";

interface Props {
  date?: Date;
  minutesRead?: string;   // e.g. "3 min read" — from remarkPluginFrontmatter (blog only, D-11)
  role?: string;          // case study only
  timeline?: string;      // case study only
  tags?: string[];
  collection?: "blog" | "projects" | "caseStudies";  // for tag link routing (D-12)
}

const {
  date,
  minutesRead,
  role,
  timeline,
  tags = [],
  collection = "blog",
} = Astro.props;

const formattedDate = date
  ? date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  : null;

// Build the text items for the meta strip (dot-separated)
const isoDate = date ? date.toISOString().slice(0, 10) : null;

const textItems: string[] = [];
if (minutesRead) textItems.push(minutesRead);
if (role) textItems.push(role);
if (timeline) textItems.push(timeline);
---

<div class="meta-strip">
  {(formattedDate || textItems.length > 0) && (
    <span class="meta-text">
      {formattedDate && (
        <time datetime={isoDate}>{formattedDate}</time>
      )}{formattedDate && textItems.length > 0 && " · "}{textItems.join(" · ")}
    </span>
  )}
  {tags.length > 0 && (
    <div class="meta-tags">
      {tags.map((tag) => (
        <TagChip tag={tag} collection={collection} />
      ))}
    </div>
  )}
</div>

<style>
  /* Engineer-classic: mono small caps for the dot-separated meta text,
     tighter rhythm; tags row picks up its own spacing below. */
  .meta-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-top: 4px;
  }

  .meta-text {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.03em;
    color: var(--color-muted);
  }

  .meta-text time {
    color: var(--color-ink);
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
</style>
