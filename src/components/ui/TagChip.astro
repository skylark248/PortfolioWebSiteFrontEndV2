---
// src/components/ui/TagChip.astro
// Reusable tag pill link atom. Links to the per-collection tag index page (D-12).
// WCAG 2.5.5: min-height 44px for touch target compliance.

interface Props {
  tag: string;
  collection: "blog" | "projects" | "caseStudies";
}

const { tag, collection } = Astro.props;

// Map collection name to URL path segment (D-12 per-collection tag routes)
const collectionPath =
  collection === "caseStudies" ? "case-studies" : collection;
const href = `/${collectionPath}/tags/${encodeURIComponent(tag)}`;
---

<a
  href={href}
  class="tag-chip"
>
  {tag}
</a>

<style>
  /* Engineer-classic: drop the pill + warm bg in favor of a mono, flat,
     hairline-bordered chip that matches SkillsGrouped (landing /Stack).
     WCAG 2.5.5 touch target preserved via min-height: 44px on the link
     even though the visible chip is tighter. */
  .tag-chip {
    display: inline-flex;
    align-items: center;
    min-height: 44px; /* WCAG 2.5.5 touch target */
    padding: 4px 10px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.01em;
    text-decoration: none;
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
    transition:
      color var(--motion-duration-fast) var(--motion-ease-out),
      border-color var(--motion-duration-fast) var(--motion-ease-out),
      background var(--motion-duration-fast) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out);
  }

  .tag-chip:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--state-hover, color-mix(in srgb, var(--color-accent) 8%, transparent));
    transform: translateY(-1px); /* D-15: CSS-only hover lift */
  }

  /* M3 press feedback — minimal scale-down + state-press surface.
     100ms (M3 short-2) on the way in, emphasized-accelerate ease for the
     "snap" feel. Spring returns on release. Not a literal ripple — that
     would clash with the engineer-classic restraint. */
  .tag-chip:active {
    transform: scale(0.94);
    background: var(--state-press, color-mix(in srgb, var(--color-accent) 12%, transparent));
    transition:
      transform var(--dur-short-2, 100ms) var(--ease-exit, cubic-bezier(0.3,0,0.8,0.15)),
      background var(--dur-short-2, 100ms) var(--ease-standard, ease-out),
      color var(--motion-duration-fast) var(--motion-ease-out),
      border-color var(--motion-duration-fast) var(--motion-ease-out);
  }

  /* D-15: suppress hover lift + press scale under reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .tag-chip { transition: none; }
    .tag-chip:hover { transform: none; }
    .tag-chip:active { transform: none; }
  }
</style>
