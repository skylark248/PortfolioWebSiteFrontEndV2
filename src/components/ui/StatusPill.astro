---
// Neutral status pill atom — D-03 (NOT green, NOT accent; overrides LAND-01 "open to work" framing).
interface Props {
  label: string;       // visible text, e.g. "Currently @ Morgan Stanley"
  ariaLabel?: string;  // optional long-form for assistive tech
}
const { label, ariaLabel } = Astro.props;
---
<span class="status-pill" aria-label={ariaLabel}>{label}</span>

<style>
  .status-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    height: 28px;                    /* UI-SPEC: pill height 28px, not a touch target */
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    /* WCAG 2.1 AA: use --color-ink (not --color-muted) so contrast ≥ 4.5:1
       on any card/page background. --color-muted (#6b6b6b) failed against
       the landing page card mix backgrounds (axe violation, Rule 2 fix). */
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-muted) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-muted) 20%, transparent);
    /* No transition — pill is static, not interactive. */
  }
</style>
