---
import ThemeToggle from "../theme/ThemeToggle.astro";
---

<!-- Hamburger button: visible only on mobile via CSS -->
<button
  id="hamburger-toggle"
  type="button"
  class="hamburger-btn"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-menu-panel"
>
  <!-- Three-line icon (bars) — aria-hidden so button label is the accessible name -->
  <svg
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    aria-hidden="true"
    focusable="false"
  >
    <line x1="3" y1="6" x2="21" y2="6" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
</button>

<!-- Mobile menu panel: hidden by default -->
<div
  id="mobile-menu-panel"
  class="mobile-menu-panel"
  hidden
  role="dialog"
  aria-modal="false"
  aria-label="Site navigation"
>
  <nav aria-label="Mobile site navigation">
    <ul class="mobile-nav-links" role="list">
      <li><a href="/" class="mobile-nav-link">Home</a></li>
      <li><a href="/blog" class="mobile-nav-link">Blog</a></li>
      <li><a href="/projects" class="mobile-nav-link">Projects</a></li>
      <li><a href="/case-studies" class="mobile-nav-link">Case Studies</a></li>
      <li><a href="/about" class="mobile-nav-link">About</a></li>
      <li><a href="/contact" class="mobile-nav-link">Contact</a></li>
      <li><a href="/resume" class="mobile-nav-link">Resume</a></li>
    </ul>
  </nav>
  <div class="mobile-menu-footer">
    <ThemeToggle />
  </div>
</div>

<script>
  function initHamburger() {
    const btn = document.getElementById("hamburger-toggle") as HTMLButtonElement | null;
    const panel = document.getElementById("mobile-menu-panel") as HTMLElement | null;
    if (!btn || !panel) return;

    function openMenu() {
      panel!.hidden = false;
      btn!.setAttribute("aria-expanded", "true");
      btn!.setAttribute("aria-label", "Close menu");
      // Focus the first link inside the panel
      const firstLink = panel!.querySelector<HTMLElement>("a, button");
      if (firstLink) firstLink.focus();
    }

    function closeMenu() {
      panel!.hidden = true;
      btn!.setAttribute("aria-expanded", "false");
      btn!.setAttribute("aria-label", "Open menu");
      btn!.focus();
    }

    // Toggle on button click
    btn.addEventListener("click", () => {
      const isOpen = btn!.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    // Escape key closes the menu
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && btn!.getAttribute("aria-expanded") === "true") {
        closeMenu();
      }
    });

    // Close menu on View Transitions navigation
    // astro:after-swap fires after the DOM swap on every navigation
    document.addEventListener("astro:after-swap", closeMenu);

    // Focus trap: cycle Tab/Shift+Tab within the open panel
    panel.addEventListener("keydown", (e) => {
      if (e.key !== "Tab") return;
      const focusable = Array.from(
        panel!.querySelectorAll<HTMLElement>("a, button, [tabindex]:not([tabindex='-1'])")
      ).filter((el) => !el.closest("[hidden]") && el !== panel);
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }

  // astro:page-load fires on initial load and after each View Transition
  // Because <header> uses transition:persist, this actually only fires once on initial load
  // and is NOT re-fired on navigation. This is intentional — initHamburger() runs once.
  document.addEventListener("astro:page-load", initHamburger);
</script>

<style>
  /* Hamburger button: hidden on desktop, visible on mobile */
  .hamburger-btn {
    display: none;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    color: var(--color-ink);
    border-radius: 4px;
  }

  .hamburger-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .hamburger-btn { display: flex; align-items: center; justify-content: center; }
  }

  /* Mobile menu panel */
  .mobile-menu-panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 80px 24px 32px;
    overflow-y: auto;
    /* Slide-in animation — suppressed under prefers-reduced-motion */
    animation: slideDown 200ms var(--motion-ease-out, ease-out) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu-panel {
      animation: none;
    }
  }

  @keyframes slideDown {
    from { transform: translateY(-8px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .mobile-nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-nav-link {
    display: block;
    padding: 12px 8px;
    font-size: 20px;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    border-radius: 6px;
    transition: color 120ms ease-out, background 120ms ease-out;
  }

  .mobile-nav-link:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .mobile-nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .mobile-menu-footer {
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 20%, transparent);
  }

  /* Hide panel on desktop — it should only ever be opened on mobile */
  @media (min-width: 769px) {
    .mobile-menu-panel { display: none !important; }
  }
</style>
