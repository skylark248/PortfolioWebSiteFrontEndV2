---
// src/components/cards/ProjectCard.astro
// Reusable project card extracted from src/pages/projects/index.astro.
// Used by the projects listing and the landing page (Plan 03-06).

import { Image } from "astro:assets";
import TagChip from "../ui/TagChip.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  loading?: "lazy" | "eager";
}
const { project, loading = "lazy" } = Astro.props;
---

<article class="project-card">
  {project.data.heroImage && (
    <a href={`/projects/${project.id}/`} tabindex="-1" aria-hidden="true">
      <Image
        src={project.data.heroImage}
        alt={project.data.title}
        loading={loading}
        widths={[400, 800]}
        sizes="(min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
        class="card-hero"
      />
    </a>
  )}
  <div class="card-body">
    {/* view-transition-name on the heading itself (not the anchor) so the
       morph target matches the detail page's h1. */}
    <h2 class="card-title" style={`view-transition-name: project-${project.id};`}>
      <a href={`/projects/${project.id}/`}>{project.data.title}</a>
    </h2>
    <p class="card-summary">{project.data.summary}</p>
    <div class="card-meta">
      <div class="card-tags">
        {project.data.tags.map((tag) => (
          <TagChip tag={tag} collection="projects" />
        ))}
      </div>
      <div class="card-links">
        {project.data.repoUrl && (
          <a
            href={project.data.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View source on GitHub"
            class="card-icon-link"
          >
            <!-- GitHub icon (16x16 inline SVG) -->
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
        )}
        {project.data.demoUrl && (
          <a
            href={project.data.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View live demo"
            class="card-icon-link"
          >
            <!-- External link icon (16x16 inline SVG) -->
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 2H3a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1V9.5h-1.5V13H3V3h3.5V1.5L6.5 2zM9 1.5V3h3.44l-5.72 5.72 1.06 1.06L13.5 4.06V7.5H15V1.5H9z"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</article>

<style>
  /* Engineer-classic: hairline border, flat, accent on hover. */
  .project-card {
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    overflow: hidden;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      box-shadow var(--motion-duration-base) var(--motion-ease-out);
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-line));
    transform: translateY(-3px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
    .project-card:hover { transform: none; box-shadow: none; }
  }

  .card-hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--color-line);
  }

  .card-body {
    padding: 20px 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .card-title {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .card-title a {
    color: var(--color-ink);
    text-decoration: none;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }
  .card-title a:hover { color: var(--color-accent); }

  .card-summary {
    font-size: 14px;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.6;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: 4px;
  }

  .card-tags { display: flex; flex-wrap: wrap; gap: 4px; }

  .card-links {
    display: flex;
    gap: 12px;
  }

  .card-icon-link {
    color: var(--color-muted);
    display: inline-flex;
    align-items: center;
    transition: color var(--motion-duration-fast) var(--motion-ease-out),
                transform var(--motion-duration-base) var(--motion-ease-out);
  }

  .card-icon-link:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .card-icon-link { transition: none; }
    .card-icon-link:hover { transform: none; }
  }
</style>
