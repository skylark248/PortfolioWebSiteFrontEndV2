---
// src/components/cards/BlogRow.astro
// Reusable blog row extracted from src/pages/blog/index.astro.
// Used by the blog listing and the landing page (Plan 03-06).
//
// CRITICAL: Do NOT call render() inside this component.
// The calling page must compute minutesRead via render(post) and pass it as a prop.
// See RESEARCH.md Pitfall 6 — render() must stay in the calling page.

import TagChip from "../ui/TagChip.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  minutesRead?: string;
}
const { post, minutesRead } = Astro.props;
const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const metaText = [formattedDate, minutesRead].filter(Boolean).join(" · ");
---

<li class="post-row">
  {/* view-transition-name on the title link so the row text morphs into
     the detail page's h1 on navigation (paired with BlogPostLayout). */}
  <a href={`/blog/${post.id}/`} class="post-title-link" style={`view-transition-name: blog-${post.id};`}>
    {post.data.title}
  </a>
  <div class="post-meta">
    <span class="post-meta-text">{metaText}</span>
    <div class="post-tags">
      {post.data.tags.map((tag) => (
        <TagChip tag={tag} collection="blog" />
      ))}
    </div>
  </div>
  <p class="post-excerpt">{post.data.description}</p>
</li>

<style>
  /* Engineer-classic: accent rail on hover, no background flash. */
  .post-row {
    padding: 24px 24px 20px;
    border-bottom: 1px solid var(--color-line);
    border-left: 2px solid transparent;
    transition:
      border-left-color var(--motion-duration-base) var(--motion-ease-out),
      padding-left var(--motion-duration-base) var(--motion-ease-out);
  }

  .post-row:hover {
    border-left-color: var(--color-accent);
    padding-left: 32px;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-row { transition: none; }
    .post-row:hover { padding-left: 24px; }
  }

  .post-title-link {
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }

  .post-title-link:hover { color: var(--color-accent); }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  /* LAND-03 contract: .post-meta-text class preserved with year + reading time. */
  .post-meta-text {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
    letter-spacing: 0.03em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .post-excerpt {
    font-size: 15px;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.65;
    max-width: 64ch;
  }
</style>
