---
// src/components/cards/CaseStudyCard.astro
// Reusable case-study card extracted from src/pages/case-studies/index.astro.
// Used by the case-studies listing and the landing page (Plan 03-06).

import { Image } from "astro:assets";
import TagChip from "../ui/TagChip.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  cs: CollectionEntry<"caseStudies">;
  loading?: "lazy" | "eager";
}
const { cs, loading = "lazy" } = Astro.props;
---

<article class="cs-feature-card">
  {cs.data.heroImage && (
    <a href={`/case-studies/${cs.id}/`} class="cs-hero-link" tabindex="-1" aria-hidden="true">
      <Image
        src={cs.data.heroImage}
        alt={cs.data.title}
        loading={loading}
        widths={[800, 1200]}
        sizes="min(64rem, 100vw - 2rem)"
        class="cs-hero"
      />
    </a>
  )}
  <div class="cs-card-body">
    <a href={`/case-studies/${cs.id}/`} class="cs-card-title-link">
      <h2 class="cs-card-title">{cs.data.title}</h2>
    </a>
    <p class="cs-card-subtitle">{cs.data.subtitle}</p>
    {(cs.data.role || cs.data.timeline) && (
      <p class="cs-meta-text">
        {[cs.data.role, cs.data.timeline].filter(Boolean).join(" · ")}
      </p>
    )}
    <p class="cs-description">{cs.data.description}</p>
    <p class="cs-outcome">
      <span class="outcome-prefix">Result</span>
      <span class="outcome-text">{cs.data.outcome}</span>
    </p>
    {cs.data.tech.length > 0 && (
      <div class="cs-tech-chips">
        {cs.data.tech.map((t) => (
          <TagChip tag={t} collection="caseStudies" />
        ))}
      </div>
    )}
  </div>
</article>

<style>
  /* Engineer-classic: hairline-bordered flat card, accent rail on hover. */
  .cs-feature-card {
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    overflow: hidden;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      box-shadow var(--motion-duration-base) var(--motion-ease-out);
  }
  .cs-feature-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-line));
    transform: translateY(-3px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-feature-card { transition: none; }
    .cs-feature-card:hover { transform: none; box-shadow: none; }
  }

  .cs-hero-link { display: block; }
  .cs-hero {
    width: 100%;
    aspect-ratio: 2.5 / 1;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--color-line);
  }

  .cs-card-body {
    padding: 28px 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cs-card-title-link { text-decoration: none; }

  .cs-card-title {
    font-size: clamp(22px, 2.5vw, 26px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }
  .cs-card-title-link:hover .cs-card-title { color: var(--color-accent); }

  .cs-card-subtitle {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-muted);
    margin: 0;
  }

  .cs-meta-text {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .cs-description {
    font-size: 15px;
    color: var(--color-ink);
    margin: 4px 0 0;
    line-height: 1.6;
  }

  /* Outcome row: mono accent label + body */
  .cs-outcome {
    font-size: 14px;
    color: var(--color-ink);
    margin: 4px 0 0;
    line-height: 1.55;
    padding: 12px 16px;
    background: var(--color-surface);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
  }
  .outcome-prefix {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 4px;
  }
  .outcome-text { display: block; }

  .cs-tech-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }
</style>
