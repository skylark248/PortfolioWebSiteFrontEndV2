---
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TagChip from "../../../components/ui/TagChip.astro";
import { getPublishedCollection } from "../../../lib/content";

export async function getStaticPaths() {
  const projects = await getPublishedCollection("projects");
  const allTags = [...new Set(projects.flatMap((p) => p.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      projects: projects
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, projects } = Astro.props;
const displayTag = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<BaseLayout
  title={`${displayTag} — Projects`}
  description={`All projects tagged ${tag}.`}
>
  <div class="tag-listing">
    <header class="tag-header">
      <h1 class="tag-title">{displayTag}</h1>
      <p class="tag-description">
        All projects tagged {tag} — {projects.length} {projects.length === 1 ? "entry" : "entries"}
      </p>
    </header>

    {projects.length === 0 ? (
      <p class="empty-state">No projects tagged {tag} yet.</p>
    ) : (
      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            {project.data.heroImage && (
              <a href={`/projects/${project.id}/`} tabindex="-1" aria-hidden="true">
                <Image
                  src={project.data.heroImage}
                  alt={project.data.title}
                  loading="lazy"
                  widths={[400, 800]}
                  sizes="(min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
                  class="card-hero"
                />
              </a>
            )}
            <div class="card-body">
              <h2 class="card-title">
                <a href={`/projects/${project.id}/`}>{project.data.title}</a>
              </h2>
              <p class="card-summary">{project.data.summary}</p>
              <div class="card-tags">
                {project.data.tags.map((t) => (
                  <TagChip tag={t} collection="projects" />
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .tag-listing { max-width: 72rem; margin: 0 auto; padding: 64px 1rem; }
  .tag-header { margin-bottom: 40px; }
  .tag-title { font-size: 32px; font-weight: 700; line-height: 1.2; color: var(--color-ink); margin: 0 0 8px; }
  .tag-description { font-size: 14px; color: var(--color-muted); margin: 0; }
  .project-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 767px) { .project-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 479px) { .project-grid { grid-template-columns: 1fr; } }
  .project-card {
    background: color-mix(in srgb, var(--color-bg) 70%, var(--color-ink) 10%);
    border: 1px solid color-mix(in srgb, var(--color-muted) 15%, transparent);
    border-radius: 0 0 4px 4px;
    overflow: hidden;
    transition:
      box-shadow var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out);
  }
  .project-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
    .project-card:hover { transform: none; box-shadow: none; }
  }
  .card-hero { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .card-body { padding: 16px; }
  .card-title { font-size: 20px; font-weight: 700; line-height: 1.3; margin: 0 0 8px; }
  .card-title a { color: var(--color-ink); text-decoration: none; }
  .card-title a:hover { text-decoration: underline; }
  .card-summary { font-size: 16px; color: var(--color-muted); margin: 0 0 12px; line-height: 1.6; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .empty-state { font-size: 20px; font-weight: 700; color: var(--color-muted); text-align: center; margin-top: 64px; }
</style>
