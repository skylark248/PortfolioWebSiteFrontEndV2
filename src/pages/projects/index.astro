---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/cards/ProjectCard.astro";
import { getPublishedCollection } from "../../lib/content";

const all = await getPublishedCollection("projects");

// D-02: featured entries pinned first, reverse-chrono within each group
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const rest = all
  .filter((p) => !p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const hasFeaturedAndRest = featured.length > 0 && rest.length > 0;
---

<BaseLayout
  title="Projects"
  description="A selection of engineering projects — platforms, pipelines, and systems."
>
  <div class="projects-listing">
    <h1 class="listing-title">Projects</h1>

    {all.length === 0 ? (
      <p class="empty-state">No projects yet.</p>
    ) : (
      <>
        {/* Featured grid */}
        {featured.length > 0 && (
          <div class="project-grid">
            {featured.map((project) => (
              <ProjectCard project={project} loading="eager" />
            ))}
          </div>
        )}

        {/* Separator between featured and non-featured (D-02) */}
        {hasFeaturedAndRest && (
          <hr class="featured-separator" />
        )}

        {/* Non-featured grid */}
        {rest.length > 0 && (
          <div class="project-grid">
            {rest.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        )}
      </>
    )}
  </div>
</BaseLayout>

<style>
  .projects-listing {
    max-width: 72rem;
    margin: 0 auto;
    padding: 64px 1rem;
  }

  .listing-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 40px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 767px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 479px) {
    .project-grid { grid-template-columns: 1fr; }
  }

  .featured-separator {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 30%, transparent);
    margin: 32px 0;
  }

  .empty-state {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-muted);
    text-align: center;
    margin-top: 64px;
  }
</style>
