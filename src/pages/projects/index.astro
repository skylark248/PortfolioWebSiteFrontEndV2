---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagChip from "../../components/ui/TagChip.astro";
import { getPublishedCollection } from "../../lib/content";

const all = await getPublishedCollection("projects");

// D-02: featured entries pinned first, reverse-chrono within each group
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const rest = all
  .filter((p) => !p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const hasFeaturedAndRest = featured.length > 0 && rest.length > 0;
---

<BaseLayout
  title="Projects"
  description="A selection of engineering projects — platforms, pipelines, and systems."
>
  <div class="projects-listing">
    <h1 class="listing-title">Projects</h1>

    {all.length === 0 ? (
      <p class="empty-state">No projects yet.</p>
    ) : (
      <>
        {/* Featured grid */}
        {featured.length > 0 && (
          <div class="project-grid">
            {featured.map((project) => (
              <article class="project-card">
                {project.data.heroImage && (
                  <a href={`/projects/${project.id}/`} tabindex="-1" aria-hidden="true">
                    <Image
                      src={project.data.heroImage}
                      alt={project.data.title}
                      loading="lazy"
                      widths={[400, 800]}
                      sizes="(min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
                      class="card-hero"
                    />
                  </a>
                )}
                <div class="card-body">
                  <h2 class="card-title">
                    <a href={`/projects/${project.id}/`}>{project.data.title}</a>
                  </h2>
                  <p class="card-summary">{project.data.summary}</p>
                  <div class="card-meta">
                    <div class="card-tags">
                      {project.data.tags.map((tag) => (
                        <TagChip tag={tag} collection="projects" />
                      ))}
                    </div>
                    <div class="card-links">
                      {project.data.repoUrl && (
                        <a
                          href={project.data.repoUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label="View source on GitHub"
                          class="card-icon-link"
                        >
                          <!-- GitHub icon (16x16 inline SVG) -->
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                          </svg>
                        </a>
                      )}
                      {project.data.demoUrl && (
                        <a
                          href={project.data.demoUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label="View live demo"
                          class="card-icon-link"
                        >
                          <!-- External link icon (16x16 inline SVG) -->
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 2H3a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1V9.5h-1.5V13H3V3h3.5V1.5L6.5 2zM9 1.5V3h3.44l-5.72 5.72 1.06 1.06L13.5 4.06V7.5H15V1.5H9z"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}

        {/* Separator between featured and non-featured (D-02) */}
        {hasFeaturedAndRest && (
          <hr class="featured-separator" />
        )}

        {/* Non-featured grid */}
        {rest.length > 0 && (
          <div class="project-grid">
            {rest.map((project) => (
              <article class="project-card">
                {project.data.heroImage && (
                  <a href={`/projects/${project.id}/`} tabindex="-1" aria-hidden="true">
                    <Image
                      src={project.data.heroImage}
                      alt={project.data.title}
                      loading="lazy"
                      widths={[400, 800]}
                      sizes="(min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
                      class="card-hero"
                    />
                  </a>
                )}
                <div class="card-body">
                  <h2 class="card-title">
                    <a href={`/projects/${project.id}/`}>{project.data.title}</a>
                  </h2>
                  <p class="card-summary">{project.data.summary}</p>
                  <div class="card-meta">
                    <div class="card-tags">
                      {project.data.tags.map((tag) => (
                        <TagChip tag={tag} collection="projects" />
                      ))}
                    </div>
                    <div class="card-links">
                      {project.data.repoUrl && (
                        <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" aria-label="View source on GitHub" class="card-icon-link">
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                          </svg>
                        </a>
                      )}
                      {project.data.demoUrl && (
                        <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer" aria-label="View live demo" class="card-icon-link">
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 2H3a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1V9.5h-1.5V13H3V3h3.5V1.5L6.5 2zM9 1.5V3h3.44l-5.72 5.72 1.06 1.06L13.5 4.06V7.5H15V1.5H9z"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </>
    )}
  </div>
</BaseLayout>

<style>
  .projects-listing {
    max-width: 72rem;
    margin: 0 auto;
    padding: 64px 1rem;
  }

  .listing-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 40px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 767px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 479px) {
    .project-grid { grid-template-columns: 1fr; }
  }

  .featured-separator {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 30%, transparent);
    margin: 32px 0;
  }

  .project-card {
    background: color-mix(in srgb, var(--color-bg) 70%, var(--color-ink) 10%);
    border: 1px solid color-mix(in srgb, var(--color-muted) 15%, transparent);
    border-radius: 0 0 4px 4px;
    overflow: hidden;
    transition:
      box-shadow var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out);
  }

  .project-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
    .project-card:hover { transform: none; box-shadow: none; }
  }

  .card-hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .card-body { padding: 16px; }

  .card-title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .card-title a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .card-title a:hover { text-decoration: underline; }

  .card-summary {
    font-size: 16px;
    color: var(--color-muted);
    margin: 0 0 12px;
    line-height: 1.6;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .card-tags { display: flex; flex-wrap: wrap; gap: 4px; }

  .card-links {
    display: flex;
    gap: 8px;
  }

  .card-icon-link {
    color: var(--color-muted);
    transition: color var(--motion-duration-fast) var(--motion-ease-out);
  }

  .card-icon-link:hover { color: var(--color-accent); }

  @media (prefers-reduced-motion: reduce) {
    .card-icon-link { transition: none; }
  }

  .empty-state {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-muted);
    text-align: center;
    margin-top: 64px;
  }
</style>
