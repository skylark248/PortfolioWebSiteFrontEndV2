---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactInfoCard from "../components/contact/ContactInfoCard.astro";
import TurnstileWidget from "../components/contact/TurnstileWidget.astro";
import { resume } from "../data/resume";

const basics = resume.basics!;

const linkedinUrl =
  basics.profiles.find((p) => p.network === "LinkedIn")?.url ??
  "https://www.linkedin.com/in/shivanshc248";
const githubUrl =
  basics.profiles.find((p) => p.network === "GitHub")?.url ??
  "https://github.com/skylark248";
---

<BaseLayout
  title="Contact — Shivansh Choudhary"
  description="Get in touch — send a message, email me directly, or save my contact card."
>
  <div class="contact-page">
    <header class="contact-header">
      <p class="contact-eyebrow">Say hi</p>
      <h1 class="contact-title">Get in touch.</h1>
      <p class="contact-intro">
        Best way to reach me is the form on the left — Netlify Forms +
        Cloudflare Turnstile, so it lands in my inbox without giving spam
        a foothold. I read everything and reply within a couple of days.
      </p>
    </header>
    <div class="contact-grid">
      <div class="contact-info-col">
        <ContactInfoCard
          email={basics.email!}
          linkedinUrl={linkedinUrl}
          githubUrl={githubUrl}
          vcfPath="/shivansh.vcf"
        />
      </div>
      <div class="contact-form-col">
        <form
          name="contact"
          method="POST"
          action="/thanks"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="contact-form"
        >
          <input type="hidden" name="form-name" value="contact" />

          <!-- Honeypot: visually hidden, bots fill it, Netlify rejects the submission -->
          <p hidden aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <div class="form-group">
            <label for="name" class="form-label">Name <span aria-hidden="true">*</span></label>
            <input id="name" name="name" type="text" class="form-input" required autocomplete="name" />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email <span aria-hidden="true">*</span></label>
            <input id="email" name="email" type="email" class="form-input" required autocomplete="email" />
          </div>

          <div class="form-group">
            <label for="subject" class="form-label">Subject <span aria-hidden="true">*</span></label>
            <input id="subject" name="subject" type="text" class="form-input" required />
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" class="form-textarea" rows="6" minlength="10" required></textarea>
          </div>

          <TurnstileWidget />

          <button type="submit" id="contact-submit" class="submit-cta" disabled aria-label="Send message">
            Send message
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .contact-page {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) 24px clamp(64px, 9vw, 96px);
  }

  .contact-header {
    margin-bottom: clamp(40px, 6vw, 64px);
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-line);
  }

  .contact-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0 0 16px;
  }

  .contact-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    color: var(--color-ink);
  }

  .contact-intro {
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-muted);
    margin: 0;
    max-width: 56ch;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 3fr 2fr;
      align-items: start;
      gap: 56px;
    }
    .contact-info-col { order: 2; }
    .contact-form-col { order: 1; }
  }

  /* Mobile: info card above form */
  .contact-info-col { order: 1; }
  .contact-form-col { order: 2; }

  /* ── Form elements (engineer-classic) ─────────────────────── */
  .form-group { margin-bottom: 24px; }

  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-ink);
    font: inherit;
    font-size: 15px;
    line-height: 1.5;
    transition:
      border-color var(--motion-duration-base) var(--motion-ease-out),
      background var(--motion-duration-base) var(--motion-ease-out);
    box-sizing: border-box;
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: color-mix(in srgb, var(--color-muted) 70%, transparent);
  }
  .form-input:hover,
  .form-textarea:hover {
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-line));
  }
  .form-input:focus,
  .form-textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 0;
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 4%, var(--color-surface));
  }
  .form-textarea { resize: vertical; min-height: 144px; }

  /* ── Submit button (engineer-classic CTA — matches landing hero) ── */
  .submit-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 24px;
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.015em;
    cursor: pointer;
    margin-top: 16px;
    transition:
      background var(--motion-duration-base) var(--motion-ease-out),
      color var(--motion-duration-base) var(--motion-ease-out),
      border-color var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      box-shadow var(--motion-duration-base) var(--motion-ease-out);
  }
  .submit-cta:hover:not(:disabled) {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--color-accent);
  }
  .submit-cta:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    color: var(--color-muted);
    border-color: var(--color-line);
  }
  .submit-cta:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  /* Turnstile widget spacing */
  .cf-turnstile { margin: 28px 0 8px; }

  @media (prefers-reduced-motion: reduce) {
    .form-input,
    .form-textarea,
    .submit-cta { transition: none; }
    .submit-cta:hover:not(:disabled) {
      transform: none;
      box-shadow: none;
    }
  }
</style>
