---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Contact — Shivansh Choudhary"
  description="Get in touch with Shivansh Choudhary — Senior Software Engineer at Morgan Stanley."
>
  <div class="placeholder-page">
    <h1>Get in touch</h1>
    <p>Contact page is being set up — check back soon.</p>
    <a href="/">← Back to home</a>
  </div>
</BaseLayout>

<style>
  .placeholder-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 64px 1rem;
    text-align: center;
  }
  .placeholder-page h1 { font-size: 32px; font-weight: 700; color: var(--color-ink); margin-bottom: 16px; }
  .placeholder-page p  { font-size: 16px; color: var(--color-muted); margin-bottom: 24px; }
  .placeholder-page a  { font-size: 14px; color: var(--color-muted); text-decoration: none; }
  .placeholder-page a:hover { color: var(--color-ink); }
</style>
