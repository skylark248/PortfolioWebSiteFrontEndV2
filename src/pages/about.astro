---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import StatusPill from "../components/ui/StatusPill.astro";
// Drop avatar.jpg into src/assets/ to replace the SVG placeholder — see lib/avatar.ts.
import { avatar as avatarImg } from "../lib/avatar";
import { resume } from "../data/resume";

const basics = resume.basics!;

const personLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: basics.name,
  jobTitle: basics.label,
  url: "https://shivanshchoudhary.info/about",
  email: basics.email,
  sameAs: basics.profiles?.map((p) => p.url).filter(Boolean) ?? [],
});
---

<BaseLayout
  title="About — Shivansh Choudhary"
  description="Senior Software Engineer based in Jaipur, India — currently at Morgan Stanley. Background, current focus, and what I'm working on."
  jsonLd={personLd}
>
  <div class="about-page">

    {/* ── Identity header ──────────────────────────────────────── */}
    <header class="about-header">
      <Image
        src={avatarImg}
        alt="Shivansh Choudhary"
        width={160}
        height={160}
        class="about-avatar"
        loading="eager"
      />
      <div class="about-identity">
        <p class="about-eyebrow">Hi, I'm</p>
        <h1 class="about-name">{basics.name}</h1>
        <p class="about-role">Senior Software Engineer</p>
        <div class="about-status-row">
          <StatusPill
            label="Currently @ Morgan Stanley"
            ariaLabel="Currently: Senior Software Engineer at Morgan Stanley"
          />
        </div>
        <p class="about-meta">Jaipur, India · IST (UTC+5:30)</p>
      </div>
    </header>

    {/* ── 01. Now ─────────────────────────────────────────────── */}
    <section class="about-section" aria-labelledby="now-heading">
      <h2 id="now-heading" class="about-section-heading">
        <span class="about-section-number" aria-hidden="true">01.</span>
        <span class="about-section-text">Now</span>
      </h2>
      <p class="about-section-body">
        I'm a Senior Software Engineer at Morgan Stanley, working on internal
        platform tooling for trade-lifecycle management at scale. Day-to-day
        that's Java 21, distributed-systems design, and the slow-burn
        refactoring that makes future-you grateful.
      </p>
      <p class="about-section-body">
        I'm <strong>not actively job-hunting</strong>, but always open to
        interesting conversations — especially around backend architecture,
        developer tooling, or systems that ship to prod at unusual scale.
      </p>
    </section>

    {/* ── 02. Background ──────────────────────────────────────── */}
    <section class="about-section" aria-labelledby="bg-heading">
      <h2 id="bg-heading" class="about-section-heading">
        <span class="about-section-number" aria-hidden="true">02.</span>
        <span class="about-section-text">Background</span>
      </h2>
      <p class="about-section-body">
        Before Morgan Stanley I spent two years at NAV Fund Administration
        Group as the lead backend engineer on the
        <a href="/case-studies/investment-tracker-platform/" class="about-inline-link">
          Investment Tracker Platform
        </a>
        — a cross-system fund transparency layer serving 5,000+ funds and
        2,500+ daily users. Same engagement produced the
        <a href="/case-studies/cassandra-reporting-database/" class="about-inline-link">
          Cassandra reporting tier
        </a>
        that took report generation from 3 minutes to under 5 seconds, and
        a Java 8 → 21 migration that cut average GC pause times by ~70%.
      </p>
      <p class="about-section-body">
        I started at NAV as a graduate engineer (IIT Gandhinagar) and worked
        across the stack — Spring Boot services, Kafka pipelines, SQL Server
        + Cassandra schemas, and React frontends — before settling into the
        senior backend role.
      </p>
    </section>

    {/* ── 03. Stack ───────────────────────────────────────────── */}
    <section class="about-section" aria-labelledby="stack-heading">
      <h2 id="stack-heading" class="about-section-heading">
        <span class="about-section-number" aria-hidden="true">03.</span>
        <span class="about-section-text">Stack</span>
      </h2>
      <div class="about-stack-grid">
        <div class="about-stack-col">
          <h3 class="about-stack-label">Day job</h3>
          <ul class="about-stack-list">
            <li>Java 21 · Spring Boot</li>
            <li>Apache Kafka · SQL Server · Cassandra</li>
            <li>Docker · Kubernetes</li>
            <li>AWS · GitHub Actions</li>
          </ul>
        </div>
        <div class="about-stack-col">
          <h3 class="about-stack-label">On the side</h3>
          <ul class="about-stack-list">
            <li>TypeScript · Astro · React</li>
            <li>PostgreSQL · Redis</li>
            <li>Netlify · Cloudflare</li>
            <li>Playwright · Vitest</li>
          </ul>
        </div>
      </div>
      <p class="about-section-body about-stack-note">
        I reach for the boring tools first — Postgres before exotic stores,
        plain HTTP before gRPC, a monolith before microservices unless
        there's a load reason to split. Decisions get easier when the
        defaults are good.
      </p>
    </section>

    {/* ── 04. Reach out ───────────────────────────────────────── */}
    <section class="about-section about-cta-section" aria-labelledby="cta-heading">
      <h2 id="cta-heading" class="about-section-heading">
        <span class="about-section-number" aria-hidden="true">04.</span>
        <span class="about-section-text">Reach out</span>
      </h2>
      <p class="about-section-body">
        Best way to land in my inbox is the contact form — Netlify Forms
        with Turnstile, so it goes straight to me without surface-area
        for spam. My resume is one tap away.
      </p>
      <div class="about-cta" role="group" aria-label="Next steps">
        <a href="/contact" class="cta-primary">
          Get in touch <span class="cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/resume" class="cta-secondary">Read my resume</a>
      </div>
    </section>

  </div>
</BaseLayout>

<style is:global>
  .about-page {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) 24px clamp(64px, 9vw, 96px);
  }

  /* ── Identity header ─────────────────────────────────────── */
  .about-header {
    display: flex;
    align-items: center;
    gap: 40px;
    margin-bottom: clamp(56px, 9vw, 96px);
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-line);
  }

  @media (max-width: 640px) {
    .about-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
  }

  .about-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--color-muted) 18%, transparent);
    border: 1px solid var(--color-line);
  }

  @media (max-width: 640px) {
    .about-avatar { width: 112px; height: 112px; }
  }

  .about-identity {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .about-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0;
  }

  .about-name {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }

  .about-role {
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-muted);
    margin: 0;
  }

  .about-status-row { margin-top: 4px; }

  .about-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    margin: 8px 0 0;
  }

  /* ── Section headings (numbered) ─────────────────────────── */
  .about-section {
    margin-bottom: clamp(56px, 8vw, 80px);
  }
  .about-section:last-of-type { margin-bottom: 0; }

  .about-section-heading {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 24px;
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    letter-spacing: -0.01em;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-line);
    width: 100%;
  }
  .about-section-number {
    font-family: var(--font-mono);
    font-size: 0.55em;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    position: relative;
    top: -0.05em;
  }
  .about-section-text { display: inline-block; }

  .about-section-body {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-ink);
    margin: 0 0 16px;
    max-width: 64ch;
  }
  .about-section-body:last-child { margin-bottom: 0; }
  .about-section-body strong {
    color: var(--color-accent);
    font-weight: 700;
  }

  .about-inline-link {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    transition: border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .about-inline-link:hover { border-bottom-color: var(--color-accent); }

  /* ── Stack section (two-col tech list) ───────────────────── */
  .about-stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px 32px;
    margin-bottom: 24px;
  }
  .about-stack-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .about-stack-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }
  .about-stack-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink);
    line-height: 1.6;
  }
  .about-stack-list li::before {
    content: "▸ ";
    color: var(--color-accent);
    margin-right: 4px;
  }
  .about-stack-note {
    font-style: italic;
    color: var(--color-muted);
  }

  /* ── Dual CTA — Lee Robinson dense style w/ box-shadow animate ── */
  .about-cta-section .about-section-body { margin-bottom: 24px; }

  .about-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    margin-top: 8px;
  }

  /* /about uses :is:global, so cta-primary/cta-secondary here OVERRIDE the
     small variants from prior Phase 5. Engineer-classic dense styling: */
  .about-cta .cta-primary,
  .about-cta .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0.015em;
    text-decoration: none;
    transition:
      background var(--motion-duration-base) var(--motion-ease-out),
      color var(--motion-duration-base) var(--motion-ease-out),
      border-color var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      box-shadow var(--motion-duration-base) var(--motion-ease-out);
  }

  .about-cta .cta-primary {
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
  }
  .about-cta .cta-primary:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--color-accent);
  }
  .about-cta .cta-primary .cta-arrow {
    transition: transform var(--motion-duration-base) var(--motion-ease-out);
  }
  .about-cta .cta-primary:hover .cta-arrow { transform: translateX(2px); }

  .about-cta .cta-secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
  }
  .about-cta .cta-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .about-cta .cta-primary:focus-visible,
  .about-cta .cta-secondary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 6px;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-cta .cta-primary,
    .about-cta .cta-secondary,
    .about-cta .cta-primary .cta-arrow { transition: none; }
    .about-cta .cta-primary:hover {
      transform: none;
      box-shadow: none;
    }
    .about-cta .cta-primary:hover .cta-arrow { transform: none; }
  }
</style>
