---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — Page not found · Shivansh Choudhary"
  description="That page wandered off. Here are the top sections to head to instead."
>
  <div class="notfound-page">
    <div class="notfound-hero">
      <p class="notfound-status" aria-hidden="true">
        <span class="status-arrow">⌁</span>
        <span class="status-code">HTTP 404 · NOT_FOUND</span>
      </p>
      <span class="notfound-code" aria-hidden="true">404</span>
      <h1 class="notfound-headline">That page wandered off.</h1>
      <p class="notfound-sub">No worries — here are the most useful places to head instead.</p>
    </div>

    <nav class="notfound-nav" aria-label="Recovery navigation">
      <ul class="notfound-links" role="list">
        <li>
          <a href="/" class="notfound-link-card">
            <span class="link-num" aria-hidden="true">01</span>
            <span class="link-body">
              <span class="link-label">Home</span>
              <span class="link-desc">Back to the landing page</span>
            </span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
        <li>
          <a href="/blog" class="notfound-link-card">
            <span class="link-num" aria-hidden="true">02</span>
            <span class="link-body">
              <span class="link-label">Blog</span>
              <span class="link-desc">Writing on engineering and craft</span>
            </span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
        <li>
          <a href="/projects" class="notfound-link-card">
            <span class="link-num" aria-hidden="true">03</span>
            <span class="link-body">
              <span class="link-label">Projects</span>
              <span class="link-desc">Things I've built and shipped</span>
            </span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
        <li>
          <a href="/case-studies" class="notfound-link-card">
            <span class="link-num" aria-hidden="true">04</span>
            <span class="link-body">
              <span class="link-label">Case Studies</span>
              <span class="link-desc">Deep dives into bigger problems</span>
            </span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
        <li>
          <a href="/contact" class="notfound-link-card">
            <span class="link-num" aria-hidden="true">05</span>
            <span class="link-body">
              <span class="link-label">Contact</span>
              <span class="link-desc">Get in touch directly</span>
            </span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</BaseLayout>

<style>
  .notfound-page {
    max-width: 56rem;
    margin: 0 auto;
    padding: clamp(64px, 10vw, 120px) 24px clamp(64px, 9vw, 96px);
  }

  /* ── Hero ───────────────────────────────────────────────── */
  .notfound-hero {
    text-align: left;
    margin-bottom: clamp(56px, 8vw, 88px);
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-line);
  }

  .notfound-status {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0 0 24px;
  }
  .status-arrow {
    font-size: 16px;
    line-height: 1;
  }
  .status-code {
    text-transform: uppercase;
  }

  .notfound-code {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(96px, 18vw, 168px);
    font-weight: 800;
    line-height: 0.9;
    color: color-mix(in srgb, var(--color-accent) 18%, var(--color-bg));
    margin: 0 0 24px;
    letter-spacing: -0.04em;
    user-select: none;
  }

  .notfound-headline {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 16px;
    /* Morphs from landing hero h1 during cross-page View Transition. */
    view-transition-name: page-title;
  }

  .notfound-sub {
    font-size: 17px;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 48ch;
    margin: 0;
  }

  /* ── Recovery links — engineer-classic numbered list cards ─ */
  .notfound-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .notfound-link-card {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    align-items: center;
    gap: 20px;
    padding: 20px 24px;
    border: 1px solid var(--color-line);
    border-bottom: 0;
    background: transparent;
    text-decoration: none;
    transition:
      background var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      border-color var(--motion-duration-base) var(--motion-ease-out);
  }

  .notfound-links li:first-child .notfound-link-card { border-radius: 6px 6px 0 0; }
  .notfound-links li:last-child .notfound-link-card {
    border-bottom: 1px solid var(--color-line);
    border-radius: 0 0 6px 6px;
  }

  .notfound-link-card:hover {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 50%, var(--color-line));
    transform: translateX(4px);
  }

  .notfound-link-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .link-num {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .link-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .link-label {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.3;
    letter-spacing: -0.005em;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }

  .notfound-link-card:hover .link-label {
    color: var(--color-accent);
  }

  .link-desc {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .link-arrow {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--color-muted);
    transition:
      color var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out);
  }

  .notfound-link-card:hover .link-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .notfound-link-card,
    .link-label,
    .link-arrow { transition: none; }
    .notfound-link-card:hover { transform: none; }
    .notfound-link-card:hover .link-arrow { transform: none; }
  }

  /* ── Mobile tightening ──────────────────────────────────── */
  @media (max-width: 640px) {
    .notfound-link-card {
      grid-template-columns: 36px 1fr auto;
      gap: 14px;
      padding: 16px 18px;
    }
    .link-num { font-size: 12px; }
    .link-label { font-size: 16px; }
    .link-desc { font-size: 13px; }
  }
</style>
