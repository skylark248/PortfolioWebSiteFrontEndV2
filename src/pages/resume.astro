---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resume } from "../data/resume";

// ─── JSON-LD Person (D-16; matches Phase 2/3 BaseLayout jsonLd-prop pattern) ──────
// Serialized via JSON.stringify — never template literals (XSS-safe, T-04-06).
// basics is validated non-null by ResumeSchema.refine (D-03); non-null assert is safe.
const basics = resume.basics!;
const currentWork = resume.work.find((w) => !w.endDate) ?? resume.work[0];
const personLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: basics.name,
  jobTitle: basics.label,
  url: basics.url,
  email: basics.email,
  worksFor: currentWork?.name
    ? { "@type": "Organization", name: currentWork.name }
    : undefined,
  alumniOf: resume.education
    .filter((e) => e.institution)
    .map((e) => ({ "@type": "EducationalOrganization", name: e.institution })),
  knowsAbout: resume.skills.flatMap((s) => s.keywords ?? []),
  sameAs: basics.profiles.map((p) => p.url).filter(Boolean),
});

// Format helpers — kept local; no shared util needed (D-10 YAGNI).
const fmtDate = (iso: string | undefined) => {
  if (!iso) return "Present";
  const [y, m] = iso.split("-");
  return m
    ? `${["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"][Number(m) - 1]} ${y}`
    : y;
};

const lastUpdated = resume.meta?.lastModified
  ? new Date(resume.meta.lastModified).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
    })
  : null;
---

<BaseLayout
  title="Resume — Shivansh Choudhary"
  description="Senior Software Engineer — full resume with experience, skills, projects, and a one-page ATS-friendly PDF download."
  jsonLd={personLd}
>
  <article class="resume-page">
    <div class="resume-header">
      <p class="resume-eyebrow">Curriculum vitae</p>
      <h1>{basics.name}</h1>
      <p class="resume-subhead">
        {basics.label}
        {
          basics.location?.city &&
            ` · ${basics.location.city}, ${basics.location.countryCode ?? ""}`
        }
      </p>
      <p class="resume-contact">
        {
          basics.email && (
            <a href={`mailto:${basics.email}`}>{basics.email}</a>
          )
        }
        {
          basics.phone && (
            <>
              {" · "}
              <a href={`tel:${basics.phone.replace(/\s+/g, "")}`}>
                {basics.phone}
              </a>
            </>
          )
        }
        {
          basics.profiles.map((p) => (
            <>
              {" · "}
              <a href={p.url} rel="noopener">
                {p.network}
                {p.username ? `/${p.username}` : ""}
              </a>
            </>
          ))
        }
      </p>
      {lastUpdated && <p class="last-updated">Last updated {lastUpdated}</p>}
      <p class="cta-row">
        <a
          class="download-cta"
          href="/resume.pdf"
          download="Shivansh_Choudhary_Resume_2026.pdf"
          aria-label="Download resume as PDF"
        >Download PDF <span class="cta-arrow" aria-hidden="true">→</span></a>
        <span class="cta-helper">Or press Cmd / Ctrl + P to print this page.</span>
      </p>
    </div>

    <section class="resume-section">
      <h2><span class="section-num" aria-hidden="true">01.</span><span class="section-text">Experience</span></h2>
      {
        resume.work.map((w) => (
          <article class="work-entry">
            <h3>
              {w.position}
              {w.name && (
                <>
                  {" @ "}
                  <span class="work-company">{w.name}</span>
                </>
              )}
            </h3>
            <p class="work-meta">
              {fmtDate(w.startDate)} – {fmtDate(w.endDate)}
              {w.location && ` · ${w.location}`}
            </p>
            {w.summary && <p class="work-summary">{w.summary}</p>}
            {w.highlights.length > 0 && (
              <ul class="work-highlights">
                {w.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
          </article>
        ))
      }
    </section>

    <section class="resume-section">
      <h2><span class="section-num" aria-hidden="true">02.</span><span class="section-text">Skills</span></h2>
      <ul class="skills-list">
        {
          resume.skills.map((s) => (
            <li class="skill-group">
              <strong>{s.name}:</strong> {s.keywords.join(", ")}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="resume-section">
      <h2><span class="section-num" aria-hidden="true">03.</span><span class="section-text">Projects</span></h2>
      {
        resume.projects.map((p) => (
          <article class="project-entry">
            <h3>
              {p.url ? (
                <a href={p.url} rel="noopener">
                  {p.name}
                </a>
              ) : (
                p.name
              )}
            </h3>
            {p.description && <p>{p.description}</p>}
            {p.keywords.length > 0 && (
              <p class="project-keywords">{p.keywords.join(" · ")}</p>
            )}
          </article>
        ))
      }
    </section>

    <section class="resume-section">
      <h2><span class="section-num" aria-hidden="true">04.</span><span class="section-text">Education</span></h2>
      {
        resume.education.map((e) => (
          <article class="education-entry">
            <h3>{e.institution}</h3>
            <p>
              {e.studyType}
              {e.area && ` · ${e.area}`}
            </p>
            <p class="education-meta">
              {fmtDate(e.startDate)} – {fmtDate(e.endDate)}
            </p>
          </article>
        ))
      }
    </section>
  </article>
</BaseLayout>

<style is:global>
  /* ─── Screen styles (engineer-classic) ────────────────────────────────── */
  .resume-page {
    max-width: 56rem;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) 24px clamp(64px, 9vw, 96px);
  }

  .resume-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-line);
    margin-bottom: clamp(48px, 7vw, 72px);
  }

  .resume-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin: 0 0 16px;
  }

  .resume-header h1 {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 12px;
    /* Morphs from landing hero h1 during cross-page View Transition. */
    view-transition-name: page-title;
  }
  .resume-subhead {
    font-size: clamp(17px, 2.2vw, 20px);
    font-weight: 500;
    color: var(--color-muted);
    margin: 0 0 16px;
  }
  .resume-contact {
    font-family: var(--font-mono);
    color: var(--color-muted);
    margin: 0 0 12px;
    font-size: 13px;
    letter-spacing: 0.02em;
    line-height: 1.7;
  }
  .resume-contact a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 1px;
    transition:
      color var(--motion-duration-base) var(--motion-ease-out),
      border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .resume-contact a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .last-updated {
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 12px;
    letter-spacing: 0.03em;
    margin: 0 0 24px;
  }

  .cta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0 0;
    flex-wrap: wrap;
  }

  /* Download CTA — matches landing hero + /about + /contact CTA pattern */
  .download-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 48px;
    padding: 0 24px;
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.015em;
    text-decoration: none;
    transition:
      background var(--motion-duration-base) var(--motion-ease-out),
      transform var(--motion-duration-base) var(--motion-ease-out),
      box-shadow var(--motion-duration-base) var(--motion-ease-out);
  }
  .download-cta:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--color-accent);
  }
  .download-cta .cta-arrow {
    transition: transform var(--motion-duration-base) var(--motion-ease-out);
  }
  .download-cta:hover .cta-arrow { transform: translateX(2px); }
  .cta-helper {
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 12px;
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: reduce) {
    .download-cta,
    .download-cta .cta-arrow,
    .resume-contact a { transition: none; }
    .download-cta:hover {
      transform: none;
      box-shadow: none;
    }
    .download-cta:hover .cta-arrow { transform: none; }
  }

  .resume-section {
    margin-top: clamp(40px, 6vw, 56px);
  }
  .resume-section h2 {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-line);
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .resume-section h2 .section-num {
    font-family: var(--font-mono);
    font-size: 0.55em;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    position: relative;
    top: -0.05em;
  }
  .resume-section h2 .section-text { display: inline-block; }

  .work-entry,
  .project-entry,
  .education-entry {
    margin-bottom: 32px;
    padding-left: 16px;
    border-left: 2px solid var(--color-line);
  }
  .work-entry h3,
  .project-entry h3,
  .education-entry h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0 0 6px;
    letter-spacing: -0.005em;
  }
  .work-company {
    color: var(--color-accent);
    font-weight: 600;
  }
  .work-meta,
  .education-meta {
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 12px;
    letter-spacing: 0.03em;
    margin: 0 0 12px;
  }
  .work-summary {
    margin: 0 0 12px;
    color: var(--color-ink);
    line-height: 1.65;
  }
  .work-highlights {
    margin: 0;
    padding-left: 20px;
    color: var(--color-ink);
  }
  .work-highlights li {
    margin-bottom: 8px;
    line-height: 1.65;
  }
  .work-highlights li::marker {
    color: var(--color-accent);
  }
  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .skill-group {
    margin: 0;
    line-height: 1.65;
  }
  .skill-group strong {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: inline-block;
    margin-right: 8px;
  }
  .project-entry a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    transition: border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .project-entry a:hover {
    border-bottom-color: var(--color-accent);
  }
  .project-keywords {
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 12px;
    letter-spacing: 0.02em;
    margin: 8px 0 0;
  }

  /* ─── Print rules (D-10/D-15) ────────────────────────────────────────────
     is:global needed to hide BaseLayout's <header>/<nav>/<footer>/ThemeToggle. */
  @media print {
    @page {
      size: letter;
      margin: 0.5in 0.6in;
    }

    /* D-15: force light mode regardless of [data-theme]. The token override
       below is the load-bearing fix — without it, every element that uses
       var(--color-bg|ink|line|surface|muted) keeps painting in dark theme
       and the PDF prints navy-on-navy. Overriding the variables here
       cascades into every consumer (rails, borders, section headings, etc.) */
    :root,
    :root[data-theme="dark"],
    :root[data-theme="light"] {
      color-scheme: light;
      --color-bg: #ffffff !important;
      --color-surface: #ffffff !important;
      --color-ink: #000000 !important;
      --color-muted: #595959 !important;
      --color-line: #cccccc !important;
      --color-accent: #3d348b !important;
    }
    html,
    body {
      background: #ffffff !important;
      color: #000000 !important;
    }

    /* D-10: hide layout chrome */
    header,
    nav,
    footer,
    .download-cta,
    .cta-row,
    .last-updated,
    .resume-eyebrow,
    .section-num,
    .cta-arrow {
      display: none !important;
    }

    /* Strip engineer-classic screen ornaments (mono fonts, letter-spacing,
       uppercase, accent borders, vertical rails) for ATS-friendly print. */
    .resume-page,
    .resume-contact,
    .resume-contact a,
    .work-meta,
    .education-meta,
    .project-keywords,
    .skill-group strong,
    .resume-section h2,
    .resume-section h2 .section-text {
      font-family: inherit !important;
      letter-spacing: normal !important;
      text-transform: none !important;
      border: 0 !important;
      padding-left: 0 !important;
    }
    .work-entry,
    .project-entry,
    .education-entry {
      border-left: 0 !important;
      padding-left: 0 !important;
    }
    .resume-section h2 {
      gap: 0 !important;
    }
    .resume-header {
      border-bottom: 0 !important;
      padding-bottom: 0 !important;
      margin-bottom: 24px !important;
    }
    .resume-contact a {
      color: #3d348b !important;
    }

    /* D-12: keep accent on name + section headings in print */
    .resume-page h1,
    .resume-page h2 {
      color: #3d348b !important;
    }

    /* D-08: avoid breaking inside an entry */
    .work-entry,
    .project-entry,
    .education-entry {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    /* Print typography (UI-SPEC) */
    body {
      font-size: 10.5pt;
      line-height: 1.35;
    }
    .resume-page h1 {
      font-size: 16pt;
    }
    .resume-page h2 {
      font-size: 11pt;
    }
    .resume-page {
      padding: 0;
      max-width: none;
    }

    /* Show URL alongside link text for printed recruiter clarity */
    .resume-page a[href^="http"]::after {
      content: " (" attr(href) ")";
      font-size: 9pt;
      color: #595959;
    }
  }
</style>
