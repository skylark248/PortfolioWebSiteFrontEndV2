---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resume } from "../data/resume";

// ─── JSON-LD Person (D-16; matches Phase 2/3 BaseLayout jsonLd-prop pattern) ──────
// Serialized via JSON.stringify — never template literals (XSS-safe, T-04-06).
// basics is validated non-null by ResumeSchema.refine (D-03); non-null assert is safe.
const basics = resume.basics!;
const currentWork = resume.work.find((w) => !w.endDate) ?? resume.work[0];
const personLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: basics.name,
  jobTitle: basics.label,
  url: basics.url,
  email: basics.email,
  worksFor: currentWork?.name
    ? { "@type": "Organization", name: currentWork.name }
    : undefined,
  alumniOf: resume.education
    .filter((e) => e.institution)
    .map((e) => ({ "@type": "EducationalOrganization", name: e.institution })),
  knowsAbout: resume.skills.flatMap((s) => s.keywords ?? []),
  sameAs: basics.profiles.map((p) => p.url).filter(Boolean),
});

// Format helpers — kept local; no shared util needed (D-10 YAGNI).
const fmtDate = (iso: string | undefined) => {
  if (!iso) return "Present";
  const [y, m] = iso.split("-");
  return m
    ? `${["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"][Number(m) - 1]} ${y}`
    : y;
};

const lastUpdated = resume.meta?.lastModified
  ? new Date(resume.meta.lastModified).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
    })
  : null;
---

<BaseLayout
  title="Resume — Shivansh Choudhary"
  description="Senior Software Engineer — full resume with experience, skills, projects, and a one-page ATS-friendly PDF download."
  jsonLd={personLd}
>
  <article class="resume-page">
    <div class="resume-header">
      <h1>{basics.name}</h1>
      <p class="resume-subhead">
        {basics.label}
        {
          basics.location?.city &&
            ` · ${basics.location.city}, ${basics.location.countryCode ?? ""}`
        }
      </p>
      <p class="resume-contact">
        {
          basics.email && (
            <a href={`mailto:${basics.email}`}>{basics.email}</a>
          )
        }
        {
          basics.phone && (
            <>
              {" · "}
              <a href={`tel:${basics.phone.replace(/\s+/g, "")}`}>
                {basics.phone}
              </a>
            </>
          )
        }
        {
          basics.profiles.map((p) => (
            <>
              {" · "}
              <a href={p.url} rel="noopener">
                {p.network}
                {p.username ? `/${p.username}` : ""}
              </a>
            </>
          ))
        }
      </p>
      {lastUpdated && <p class="last-updated">Last updated {lastUpdated}</p>}
      <p class="cta-row">
        <a
          class="download-cta"
          href="/resume.pdf"
          download="Shivansh_Choudhary_Resume_2026.pdf"
          aria-label="Download resume as PDF"
        >Download PDF</a>
        <span class="cta-helper">Or press Cmd / Ctrl + P to print this page.</span>
      </p>
    </div>

    <section class="resume-section">
      <h2>Experience</h2>
      {
        resume.work.map((w) => (
          <article class="work-entry">
            <h3>
              {w.position}
              {w.name && (
                <>
                  {" @ "}
                  <span class="work-company">{w.name}</span>
                </>
              )}
            </h3>
            <p class="work-meta">
              {fmtDate(w.startDate)} – {fmtDate(w.endDate)}
              {w.location && ` · ${w.location}`}
            </p>
            {w.summary && <p class="work-summary">{w.summary}</p>}
            {w.highlights.length > 0 && (
              <ul class="work-highlights">
                {w.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
          </article>
        ))
      }
    </section>

    <section class="resume-section">
      <h2>Skills</h2>
      <ul class="skills-list">
        {
          resume.skills.map((s) => (
            <li class="skill-group">
              <strong>{s.name}:</strong> {s.keywords.join(", ")}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="resume-section">
      <h2>Projects</h2>
      {
        resume.projects.map((p) => (
          <article class="project-entry">
            <h3>
              {p.url ? (
                <a href={p.url} rel="noopener">
                  {p.name}
                </a>
              ) : (
                p.name
              )}
            </h3>
            {p.description && <p>{p.description}</p>}
            {p.keywords.length > 0 && (
              <p class="project-keywords">{p.keywords.join(" · ")}</p>
            )}
          </article>
        ))
      }
    </section>

    <section class="resume-section">
      <h2>Education</h2>
      {
        resume.education.map((e) => (
          <article class="education-entry">
            <h3>{e.institution}</h3>
            <p>
              {e.studyType}
              {e.area && ` · ${e.area}`}
            </p>
            <p class="education-meta">
              {fmtDate(e.startDate)} – {fmtDate(e.endDate)}
            </p>
          </article>
        ))
      }
    </section>
  </article>
</BaseLayout>

<style is:global>
  /* ─── Screen styles (resume-page-scoped via .resume-page selector) ────── */
  .resume-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 64px 16px;
  }
  @media (min-width: 640px) {
    .resume-page {
      padding: 64px 24px;
    }
  }

  .resume-header h1 {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 8px;
  }
  @media (max-width: 640px) {
    .resume-header h1 {
      font-size: 28px;
    }
  }
  .resume-subhead {
    color: var(--color-ink);
    margin: 0 0 8px;
  }
  .resume-contact {
    color: var(--color-muted);
    margin: 0 0 8px;
    font-size: 14px;
  }
  .resume-contact a {
    color: var(--color-accent);
  }
  .last-updated {
    color: var(--color-muted);
    font-size: 14px;
    margin: 0 0 24px;
  }

  .cta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0 48px;
    flex-wrap: wrap;
  }
  .download-cta {
    display: inline-block;
    background: var(--color-accent);
    color: #ffffff;
    padding: 12px 24px;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: background 120ms var(--motion-ease-out, ease-out);
  }
  .download-cta:hover {
    background: color-mix(in srgb, var(--color-accent), black 8%);
  }
  .cta-helper {
    color: var(--color-muted);
    font-size: 14px;
  }

  .resume-section {
    margin-top: 32px;
  }
  .resume-section h2 {
    color: var(--color-accent);
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 16px;
  }
  .work-entry,
  .project-entry,
  .education-entry {
    margin-bottom: 24px;
  }
  .work-entry h3,
  .project-entry h3,
  .education-entry h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 4px;
  }
  .work-meta,
  .education-meta {
    color: var(--color-muted);
    font-size: 14px;
    margin: 0 0 8px;
  }
  .work-summary {
    margin: 0 0 8px;
  }
  .work-highlights {
    margin: 0;
    padding-left: 20px;
  }
  .work-highlights li {
    margin-bottom: 8px;
  }
  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .skill-group {
    margin-bottom: 8px;
  }
  .project-entry a {
    color: var(--color-accent);
  }
  .project-keywords {
    color: var(--color-muted);
    font-size: 14px;
    margin: 4px 0 0;
  }

  /* ─── Print rules (D-10/D-15) ────────────────────────────────────────────
     is:global needed to hide BaseLayout's <header>/<nav>/<footer>/ThemeToggle. */
  @media print {
    @page {
      size: letter;
      margin: 0.5in 0.6in;
    }

    /* D-15: force light mode regardless of [data-theme] */
    :root {
      color-scheme: light;
    }
    html,
    body {
      background: #ffffff !important;
      color: #000000 !important;
    }

    /* D-10: hide layout chrome */
    header,
    nav,
    footer,
    .download-cta,
    .cta-row,
    .last-updated {
      display: none !important;
    }

    /* D-12: keep accent on name + section headings in print */
    .resume-page h1,
    .resume-page h2 {
      color: #3d348b !important;
    }

    /* D-08: avoid breaking inside an entry */
    .work-entry,
    .project-entry,
    .education-entry {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    /* Print typography (UI-SPEC) */
    body {
      font-size: 10.5pt;
      line-height: 1.35;
    }
    .resume-page h1 {
      font-size: 16pt;
    }
    .resume-page h2 {
      font-size: 11pt;
    }
    .resume-page {
      padding: 0;
      max-width: none;
    }

    /* Show URL alongside link text for printed recruiter clarity */
    .resume-page a[href^="http"]::after {
      content: " (" attr(href) ")";
      font-size: 9pt;
      color: #595959;
    }
  }
</style>
