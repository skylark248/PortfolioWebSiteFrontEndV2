---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TagChip from "../../../components/ui/TagChip.astro";
import { getPublishedCollection } from "../../../lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedCollection("blog");
  const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

// Render all tagged posts to get minutesRead
const postsWithMeta = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return { post, minutesRead: remarkPluginFrontmatter?.minutesRead ?? "" };
  })
);

// Capitalize tag for display
const displayTag = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<BaseLayout
  title={`${displayTag} — Blog`}
  description={`All blog posts tagged ${tag}.`}
>
  <div class="tag-listing">
    <header class="tag-header">
      <h1 class="tag-title">{displayTag}</h1>
      <p class="tag-description">
        All posts tagged {tag} — {posts.length} {posts.length === 1 ? "entry" : "entries"}
      </p>
    </header>

    {postsWithMeta.length === 0 ? (
      <p class="empty-state">No posts tagged {tag} yet.</p>
    ) : (
      <ol class="post-list" role="list">
        {postsWithMeta.map(({ post, minutesRead }) => {
          const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
            month: "short",
            day: "numeric",
            year: "numeric",
          });
          const metaText = [formattedDate, minutesRead].filter(Boolean).join(" · ");
          return (
            <li class="post-row">
              <a href={`/blog/${post.id}/`} class="post-title-link">
                {post.data.title}
              </a>
              <div class="post-meta">
                <span class="post-meta-text">{metaText}</span>
                <div class="post-tags">
                  {post.data.tags.map((t) => (
                    <TagChip tag={t} collection="blog" />
                  ))}
                </div>
              </div>
              <p class="post-excerpt">{post.data.description}</p>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</BaseLayout>

<style>
  /* Reuse blog listing styles — same surface (D-12) */
  .tag-listing {
    max-width: 48rem;
    margin: 0 auto;
    padding: 64px 1rem;
  }

  .tag-header {
    margin-bottom: 40px;
  }

  .tag-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 8px;
  }

  .tag-description {
    font-size: 14px;
    color: var(--color-muted);
    margin: 0;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-row {
    padding: 24px 8px;
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 20%, transparent);
    border-radius: 4px;
    transition: background-color var(--motion-duration-fast) var(--motion-ease-out);
  }

  .post-row:hover {
    background: color-mix(in srgb, var(--color-bg) 70%, var(--color-ink) 10%);
  }

  @media (prefers-reduced-motion: reduce) {
    .post-row {
      transition: none;
    }
  }

  .post-title-link {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
  }

  .post-title-link:hover {
    text-decoration: underline;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .post-meta-text {
    font-size: 14px;
    color: var(--color-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .post-excerpt {
    font-size: 16px;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.6;
  }

  .empty-state {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-muted);
    text-align: center;
    margin-top: 64px;
  }
</style>
