---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagChip from "../../components/ui/TagChip.astro";
import { getPublishedCollection } from "../../lib/content";

// Sort reverse-chronological
const allPosts = (await getPublishedCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Render all posts to get minutesRead from remark plugin (A2: acceptable for small collections)
const postsWithMeta = await Promise.all(
  allPosts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return {
      post,
      minutesRead: remarkPluginFrontmatter?.minutesRead ?? "",
    };
  })
);
---

<BaseLayout
  title="Blog"
  description="Writing on engineering, systems, and craft."
>
  <div class="blog-listing">
    <header class="listing-header">
      <h1 class="listing-title">Blog</h1>
      <a href="/rss.xml" class="rss-link" aria-label="Subscribe via RSS">
        Subscribe via RSS
      </a>
    </header>

    {postsWithMeta.length === 0 ? (
      <p class="empty-state">No posts yet — check back soon.</p>
    ) : (
      <ol class="post-list" role="list">
        {postsWithMeta.map(({ post, minutesRead }) => {
          const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
            month: "short",
            day: "numeric",
            year: "numeric",
          });
          const metaText = [formattedDate, minutesRead].filter(Boolean).join(" · ");
          return (
            <li class="post-row">
              <a href={`/blog/${post.id}/`} class="post-title-link">
                {post.data.title}
              </a>
              <div class="post-meta">
                <span class="post-meta-text">{metaText}</span>
                <div class="post-tags">
                  {post.data.tags.map((tag) => (
                    <TagChip tag={tag} collection="blog" />
                  ))}
                </div>
              </div>
              <p class="post-excerpt">{post.data.description}</p>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</BaseLayout>

<style>
  .blog-listing {
    max-width: 48rem; /* max-w-3xl */
    margin: 0 auto;
    padding: 64px 1rem;
  }

  .listing-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .listing-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0;
  }

  .rss-link {
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
  }

  .rss-link:hover {
    color: var(--color-accent);
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-row {
    padding: 24px 8px;
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 20%, transparent);
    border-radius: 4px;
    transition: background-color var(--motion-duration-fast) var(--motion-ease-out);
  }

  .post-row:hover {
    background: color-mix(in srgb, var(--color-bg) 70%, var(--color-ink) 10%);
  }

  @media (prefers-reduced-motion: reduce) {
    .post-row {
      transition: none;
    }
  }

  .post-title-link {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
  }

  .post-title-link:hover {
    text-decoration: underline;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .post-meta-text {
    font-size: 14px;
    color: var(--color-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .post-excerpt {
    font-size: 16px;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.6;
  }

  .empty-state {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-muted);
    text-align: center;
    margin-top: 64px;
  }
</style>
