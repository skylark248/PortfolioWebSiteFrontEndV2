---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogRow from "../../components/cards/BlogRow.astro";
import { getPublishedCollection } from "../../lib/content";

// Sort reverse-chronological
const allPosts = (await getPublishedCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Render all posts to get minutesRead from remark plugin (A2: acceptable for small collections)
const postsWithMeta = await Promise.all(
  allPosts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return {
      post,
      minutesRead: remarkPluginFrontmatter?.minutesRead ?? "",
    };
  })
);
---

<BaseLayout
  title="Blog"
  description="Writing on engineering, systems, and craft."
>
  <div class="blog-listing">
    <header class="listing-header">
      <h1 class="listing-title">Blog</h1>
      <a href="/rss.xml" class="rss-link" aria-label="Subscribe via RSS">
        Subscribe via RSS
      </a>
    </header>

    {postsWithMeta.length === 0 ? (
      <p class="empty-state">No posts yet — check back soon.</p>
    ) : (
      <ol class="post-list" role="list">
        {postsWithMeta.map(({ post, minutesRead }) => (
          <BlogRow post={post} minutesRead={minutesRead} />
        ))}
      </ol>
    )}
  </div>
</BaseLayout>

<style>
  .blog-listing {
    max-width: 48rem; /* max-w-3xl */
    margin: 0 auto;
    padding: 64px 1rem;
  }

  .listing-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .listing-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0;
  }

  .rss-link {
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
  }

  .rss-link:hover {
    color: var(--color-accent);
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .empty-state {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-muted);
    text-align: center;
    margin-top: 64px;
  }
</style>
