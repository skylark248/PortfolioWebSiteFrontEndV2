---
// src/pages/case-studies/index.astro
// Case studies listing page — feature-card list (PROJ-03, D-01, D-02).

import BaseLayout from "../../layouts/BaseLayout.astro";
import CaseStudyCard from "../../components/cards/CaseStudyCard.astro";
import { getPublishedCollection } from "../../lib/content";

const caseStudies = (await getPublishedCollection("caseStudies")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Case Studies"
  description="In-depth technical case studies on platforms, systems, and architectural decisions."
>
  <div class="cs-listing">
    <h1 class="listing-title">Case Studies</h1>

    {caseStudies.length === 0 ? (
      <p class="empty-state">No case studies yet.</p>
    ) : (
      <div class="cs-list">
        {caseStudies.map((cs) => (
          <CaseStudyCard cs={cs} loading="eager" />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .cs-listing {
    max-width: 64rem;
    margin: 0 auto;
    padding: 64px 1rem;
  }

  .listing-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 40px;
  }

  .cs-list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .empty-state {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-muted);
    text-align: center;
    margin-top: 64px;
  }
</style>
