---
import { ClientRouter } from "astro:transitions";
import { Font, Image } from "astro:assets";
import ThemeToggle from "../components/theme/ThemeToggle.astro";
import HamburgerMenu from "../components/nav/HamburgerMenu.astro";
import SEO from "../components/seo/SEO.astro";
import Analytics from "../components/analytics/Analytics.astro";
// Engineer-classic v3.1: tiny avatar as a brand mark, left of nav links.
// Drop avatar.jpg into src/assets/ to replace the SVG placeholder — see lib/avatar.ts.
import { avatar } from "../lib/avatar";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: string;           // NEW — serialized JSON-LD string for Article structured data (D-18)
}

const { title, description, canonical, ogImage, jsonLd } = Astro.props;
const siteUrl = Astro.site!.toString();
const fullCanonical = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage ?? new URL("/og-default.png", siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO title={title} description={description} canonical={fullCanonical} ogImage={ogImageUrl} />

    {/* RSS alternate link (SEO-04) */}
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href="/rss.xml" />

    {/* Sitemap reference (SEO-03) */}
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {/* Structured data (D-18) — only rendered when jsonLd prop is provided */}
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    {
      /* INLINE BLOCKING THEME SCRIPT — runs before paint to prevent FOUC.
        D-07: localStorage first, prefers-color-scheme fallback. */
    }
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          /* Engineer-classic: dark by default. System preference is ignored
             intentionally — the brand is dark-first; users can toggle. */
          document.documentElement.dataset.theme = stored ?? "dark";
        } catch (e) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>

    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />

    <ClientRouter />

    <Analytics />
    <slot name="head" />
  </head>
  <body>
    <header transition:persist="site-header">
      <nav class="site-nav" aria-label="Site navigation">
        <div class="nav-left">
          <a href="/" class="nav-brand" aria-label="Shivansh Choudhary — Home">
            <Image
              src={avatar}
              alt=""
              width={32}
              height={32}
              class="nav-avatar"
              loading="eager"
              decoding="sync"
            />
          </a>
          <div class="nav-links">
            <a href="/" class="nav-link">Home</a>
            <a href="/blog" class="nav-link">Blog</a>
            <a href="/projects" class="nav-link">Projects</a>
            <a href="/case-studies" class="nav-link">Case Studies</a>
            <a href="/about" class="nav-link">About</a>
            <a href="/contact" class="nav-link">Contact</a>
            <a href="/resume" class="nav-link">Resume</a>
          </div>
        </div>
        <div class="nav-right">
          <ThemeToggle />
          <HamburgerMenu />
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>

    {/* astro:after-swap re-applies theme to prevent flash on View Transition nav. */}
    <script is:inline>
      document.addEventListener("astro:after-swap", () => {
        try {
          const stored = localStorage.getItem("theme");
          document.documentElement.dataset.theme = stored ?? "dark";
        } catch (e) {}
      });
    </script>
  </body>
</html>

<style is:global>
  /* Site header and nav styles (D-17, D-18) */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 15%, transparent);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: transform var(--motion-duration-base) var(--motion-ease-out);
  }
  .nav-brand:hover { transform: scale(1.06); }
  .nav-brand:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 9999px;
  }

  .nav-avatar {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    display: block;
    background: color-mix(in srgb, var(--color-muted) 18%, transparent);
    border: 1px solid var(--color-line);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Hide desktop links on mobile — hamburger replaces them. Brand stays. */
  @media (max-width: 768px) {
    .nav-links { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-brand,
    .nav-brand:hover { transition: none; transform: none; }
  }

  .nav-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 4px;
    transition: color 120ms ease-out, background 120ms ease-out;
  }

  .nav-link:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>
