---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import ThemeToggle from "../components/theme/ThemeToggle.astro";
import SEO from "../components/seo/SEO.astro";
import Analytics from "../components/analytics/Analytics.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: string;           // NEW — serialized JSON-LD string for Article structured data (D-18)
}

const { title, description, canonical, ogImage, jsonLd } = Astro.props;
const siteUrl = Astro.site!.toString();
const fullCanonical = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage ?? new URL("/og-default.png", siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO title={title} description={description} canonical={fullCanonical} ogImage={ogImageUrl} />

    {/* RSS alternate link (SEO-04) */}
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href="/rss.xml" />

    {/* Sitemap reference (SEO-03) */}
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    {/* Structured data (D-18) — only rendered when jsonLd prop is provided */}
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    {
      /* INLINE BLOCKING THEME SCRIPT — runs before paint to prevent FOUC.
        D-07: localStorage first, prefers-color-scheme fallback. */
    }
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = stored ?? (systemDark ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>

    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />

    <ClientRouter />

    <Analytics />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <ThemeToggle transition:persist />
      </nav>
    </header>
    <main>
      <slot />
    </main>

    {/* astro:after-swap re-applies theme to prevent flash on View Transition nav. */}
    <script is:inline>
      document.addEventListener("astro:after-swap", () => {
        try {
          const stored = localStorage.getItem("theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.dataset.theme = stored ?? (systemDark ? "dark" : "light");
        } catch (e) {}
      });
    </script>
  </body>
</html>
