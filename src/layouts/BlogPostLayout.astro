---
// src/layouts/BlogPostLayout.astro
// Blog post detail layout (D-06 header order, D-05 prev/next, D-18 JSON-LD).
// Wraps BaseLayout and wires MDX components per-page (D-08, Research Pattern 7).

import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import MetaStrip from "../components/ui/MetaStrip.astro";
import PrevNextNav from "../components/ui/PrevNextNav.astro";
import Callout from "../components/mdx/Callout.astro";
import Figure from "../components/mdx/Figure.astro";
import Aside from "../components/mdx/Aside.astro";
import ContactCTAStrip from "../components/cta/ContactCTAStrip.astro";

interface Props {
  entry: CollectionEntry<"blog">;
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { entry, prevPost = null, nextPost = null } = Astro.props;

// Render MDX and extract reading time injected by remark-reading-time (D-11)
const { Content, remarkPluginFrontmatter } = await render(entry);
const minutesRead: string = remarkPluginFrontmatter?.minutesRead ?? "";

// Build JSON-LD Article string for BaseLayout <head> (D-18, T-03-01)
const siteUrl = "https://shivanshchoudhary.info";
const pageUrl = new URL(`/blog/${entry.id}/`, siteUrl).toString();
const imageUrl = entry.data.heroImage
  ? new URL(entry.data.heroImage.src, siteUrl).toString()
  : new URL("/og-default.png", siteUrl).toString();

const ldObject = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  ...(entry.data.updatedDate
    ? { dateModified: entry.data.updatedDate.toISOString() }
    : {}),
  author: { "@type": "Person", name: "Shivansh Choudhary", url: siteUrl },
  publisher: { "@type": "Person", name: "Shivansh Choudhary", url: siteUrl },
  image: imageUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
};
// SECURITY: JSON.stringify — never string interpolation (T-03-01)
const jsonLd = JSON.stringify(ldObject);

// OG image for SEO component (D-19): heroImage URL if present, else og-default
const ogImage = imageUrl;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={pageUrl}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="blog-post">
    {/* Header: mono eyebrow → display title → description → meta strip → hero (D-06) */}
    <header class="post-header">
      <p class="post-eyebrow">
        <a href="/blog/" class="post-eyebrow-link">/blog</a>
      </p>
      <h1 class="post-title">{entry.data.title}</h1>
      {entry.data.description && (
        <p class="post-description">{entry.data.description}</p>
      )}
      <MetaStrip
        date={entry.data.pubDate}
        minutesRead={minutesRead}
        tags={entry.data.tags}
        collection="blog"
      />
      {entry.data.heroImage && (
        <div class="post-hero">
          <Image
            src={entry.data.heroImage}
            alt={entry.data.title}
            loading="eager"
            widths={[640, 1024, 1280]}
            sizes="min(72ch, 100vw - 2rem)"
            class="hero-image"
          />
        </div>
      )}
    </header>

    <!-- MDX prose body — components registered per-page (D-08, Research Pattern 7) -->
    <div class="post-body">
      <Content components={{ Callout, Figure, Aside }} />
    </div>

    <!-- Prev/next navigation (D-05) -->
    <PrevNextNav prevPost={prevPost} nextPost={nextPost} />
    <ContactCTAStrip />
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: min(72ch, 100% - 2rem);
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) 1rem clamp(64px, 9vw, 96px);
  }

  .post-header {
    margin-bottom: clamp(40px, 6vw, 56px);
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-line);
  }

  .post-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin: 0 0 16px;
  }
  .post-eyebrow-link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }
  .post-eyebrow-link:hover { color: var(--color-ink); }
  .post-eyebrow-link::before { content: "← "; }

  .post-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 16px;
  }

  .post-description {
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-muted);
    margin: 0 0 24px;
    max-width: 56ch;
  }

  .post-hero {
    margin-top: 32px;
  }

  .hero-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--color-line);
  }

  .post-body {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-ink);
  }

  /* Heading anchors (D-04) */
  .post-body :global(.heading-anchor) {
    opacity: 0;
    color: var(--color-accent);
    text-decoration: none;
    margin-right: 4px;
    transition: opacity var(--motion-duration-fast) var(--motion-ease-out);
  }

  .post-body :global(h2:hover .heading-anchor),
  .post-body :global(h3:hover .heading-anchor),
  .post-body :global(.heading-anchor:focus-visible) {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-body :global(.heading-anchor) { transition: none; }
  }

  /* Prose heading sizes — engineer-classic */
  .post-body :global(h2) {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 64px 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-line);
  }
  .post-body :global(h2:first-child) { margin-top: 0; }

  .post-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-ink);
    margin: 40px 0 12px;
  }

  /* Inline accents (mirrors case-study layout) */
  .post-body :global(p) { margin: 0 0 20px; }
  .post-body :global(strong) { color: var(--color-ink); font-weight: 700; }
  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    transition: border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .post-body :global(a:hover) { border-bottom-color: var(--color-accent); }
  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    color: var(--color-accent);
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid var(--color-line);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }
  .post-body :global(li) { margin-bottom: 8px; }

  /* Reusable lede style for posts that want to lead with a punchline. */
  .post-body :global(.post-lede) {
    font-size: clamp(18px, 1.9vw, 20px);
    line-height: 1.65;
    color: var(--color-ink);
    border-left: 3px solid var(--color-accent);
    padding-left: 20px;
    margin: 0 0 36px;
    max-width: 64ch;
  }
  .post-body :global(.post-lede strong) {
    color: var(--color-accent);
    font-weight: 700;
  }
</style>
