---
// src/layouts/BlogPostLayout.astro
// Blog post detail layout (D-06 header order, D-05 prev/next, D-18 JSON-LD).
// Wraps BaseLayout and wires MDX components per-page (D-08, Research Pattern 7).

import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import MetaStrip from "../components/ui/MetaStrip.astro";
import PrevNextNav from "../components/ui/PrevNextNav.astro";
import Callout from "../components/mdx/Callout.astro";
import Figure from "../components/mdx/Figure.astro";
import Aside from "../components/mdx/Aside.astro";
import ContactCTAStrip from "../components/cta/ContactCTAStrip.astro";

interface Props {
  entry: CollectionEntry<"blog">;
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { entry, prevPost = null, nextPost = null } = Astro.props;

// Render MDX and extract reading time injected by remark-reading-time (D-11)
const { Content, remarkPluginFrontmatter } = await render(entry);
const minutesRead: string = remarkPluginFrontmatter?.minutesRead ?? "";

// Build JSON-LD Article string for BaseLayout <head> (D-18, T-03-01)
const siteUrl = "https://shivanshchoudhary.info";
const pageUrl = new URL(`/blog/${entry.id}/`, siteUrl).toString();
const imageUrl = entry.data.heroImage
  ? new URL(entry.data.heroImage.src, siteUrl).toString()
  : new URL("/og-default.png", siteUrl).toString();

const ldObject = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  ...(entry.data.updatedDate
    ? { dateModified: entry.data.updatedDate.toISOString() }
    : {}),
  author: { "@type": "Person", name: "Shivansh Choudhary", url: siteUrl },
  publisher: { "@type": "Person", name: "Shivansh Choudhary", url: siteUrl },
  image: imageUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
};
// SECURITY: JSON.stringify — never string interpolation (T-03-01)
const jsonLd = JSON.stringify(ldObject);

// OG image for SEO component (D-19): heroImage URL if present, else og-default
const ogImage = imageUrl;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={pageUrl}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="blog-post">
    <!-- Header block: title → meta strip → hero image (D-06) -->
    <header class="post-header">
      <h1 class="post-title">{entry.data.title}</h1>
      <MetaStrip
        date={entry.data.pubDate}
        minutesRead={minutesRead}
        tags={entry.data.tags}
        collection="blog"
      />
      {entry.data.heroImage && (
        <div class="post-hero">
          <Image
            src={entry.data.heroImage}
            alt={entry.data.title}
            loading="eager"
            widths={[640, 1024, 1280]}
            sizes="min(65ch, 100vw - 2rem)"
            class="hero-image"
          />
        </div>
      )}
    </header>

    <!-- MDX prose body — components registered per-page (D-08, Research Pattern 7) -->
    <div class="post-body">
      <Content components={{ Callout, Figure, Aside }} />
    </div>

    <!-- Prev/next navigation (D-05) -->
    <PrevNextNav prevPost={prevPost} nextPost={nextPost} />
    <ContactCTAStrip />
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: min(65ch, 100% - 2rem);
    margin: 0 auto;
    padding: 64px 0;
  }

  .post-header {
    margin-bottom: 48px;
  }

  .post-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 16px;
  }

  .post-hero {
    margin-top: 24px;
  }

  .hero-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 6px;
  }

  .post-body {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-ink);
  }

  /* Heading anchor styles for rehype-autolink-headings (D-04) */
  .post-body :global(.heading-anchor) {
    opacity: 0;
    color: var(--color-accent);
    text-decoration: none;
    margin-right: 4px;
    transition: opacity var(--motion-duration-fast) var(--motion-ease-out);
  }

  .post-body :global(h2:hover .heading-anchor),
  .post-body :global(h3:hover .heading-anchor),
  .post-body :global(.heading-anchor:focus-visible) {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-body :global(.heading-anchor) {
      transition: none;
    }
  }

  /* Prose heading sizes (UI-SPEC Display / Heading roles) */
  .post-body :global(h2) {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.25;
    margin: 48px 0 16px;
  }

  .post-body :global(h3) {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    margin: 32px 0 12px;
  }
</style>
