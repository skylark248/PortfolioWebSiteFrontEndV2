---
// src/layouts/CaseStudyLayout.astro
// Case study detail layout (D-06 header order, D-07 section index, D-18 JSON-LD, D-05 other strip).
// Wraps BaseLayout and wires MDX components per-page (D-08, Research Pattern 7).

import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import MetaStrip from "../components/ui/MetaStrip.astro";
import SectionIndex from "../components/ui/SectionIndex.astro";
import OtherCaseStudies from "../components/ui/OtherCaseStudies.astro";
import Callout from "../components/mdx/Callout.astro";
import Figure from "../components/mdx/Figure.astro";
import Aside from "../components/mdx/Aside.astro";
import { getPublishedCollection } from "../lib/content";
import ContactCTAStrip from "../components/cta/ContactCTAStrip.astro";

interface Props {
  entry: CollectionEntry<"caseStudies">;
}

const { entry } = Astro.props;

// Render MDX — get headings for section index (D-07) and Content for MDX rendering
const { Content, headings } = await render(entry);

// Section index: only render when >= 4 H2s (D-07 — threshold at planning: >= 4)
const h2Headings = headings.filter((h) => h.depth === 2);
const showSectionIndex = h2Headings.length >= 4;

// "Other case studies" — most-recent-2 siblings (D-05)
const allCaseStudies = await getPublishedCollection("caseStudies");
const others = allCaseStudies
  .filter((cs) => cs.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

// JSON-LD Article (D-18, T-06-01 mitigation)
const siteUrl = "https://shivanshchoudhary.info";
const pageUrl = new URL(`/case-studies/${entry.id}/`, siteUrl).toString();
const imageUrl = entry.data.heroImage
  ? new URL(entry.data.heroImage.src, siteUrl).toString()
  : new URL("/og-default.png", siteUrl).toString();

const ldObject = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  author: { "@type": "Person", name: "Shivansh Choudhary", url: siteUrl },
  publisher: { "@type": "Person", name: "Shivansh Choudhary", url: siteUrl },
  image: imageUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
};
// SECURITY: JSON.stringify — never string interpolation (T-06-01)
const jsonLd = JSON.stringify(ldObject);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={pageUrl}
  ogImage={imageUrl}
  jsonLd={jsonLd}
>
  <article class="case-study-detail">
    {/* Header: mono eyebrow → display title → subtitle → meta strip → hero image (D-06) */}
    <header class="cs-header">
      <p class="cs-eyebrow">
        <a href="/case-studies/" class="cs-eyebrow-link">/case-studies</a>
      </p>
      {/* view-transition-name binds this h1 to the matching CaseStudyCard
         title on /case-studies/ + landing — the card text morphs into the
         detail h1 on navigation. */}
      <h1 class="cs-title" style={`view-transition-name: cs-${entry.id};`}>{entry.data.title}</h1>
      <p class="cs-subtitle">{entry.data.subtitle}</p>
      <MetaStrip
        role={entry.data.role}
        timeline={entry.data.timeline}
        tags={entry.data.tech}
        collection="caseStudies"
      />
      {entry.data.heroImage && (
        <div class="cs-hero">
          <Image
            src={entry.data.heroImage}
            alt={entry.data.title}
            loading="eager"
            widths={[800, 1200, 1600]}
            sizes="min(72ch, 100vw - 2rem)"
            class="hero-image"
          />
        </div>
      )}
    </header>

    <!-- Section index (D-07): rendered when >= 4 H2s -->
    {showSectionIndex && <SectionIndex headings={h2Headings} />}

    <!-- MDX prose body — MDX components registered per-page (D-08, Pattern 7) -->
    <div class="cs-body">
      <Content components={{ Callout, Figure, Aside }} />
    </div>

    <!-- "Other case studies" strip (D-05) -->
    <OtherCaseStudies others={others} />
    <ContactCTAStrip />
  </article>
</BaseLayout>

<style>
  .case-study-detail {
    max-width: min(72ch, 100% - 2rem);
    margin: 0 auto;
    padding: clamp(56px, 9vw, 96px) 1rem clamp(64px, 9vw, 96px);
  }

  .cs-header {
    margin-bottom: clamp(32px, 5vw, 48px);
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-line);
  }

  /* Mono eyebrow links back to the collection index. */
  .cs-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin: 0 0 16px;
  }
  .cs-eyebrow-link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }
  .cs-eyebrow-link:hover { color: var(--color-ink); }
  .cs-eyebrow-link::before { content: "← "; }

  .cs-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 16px;
  }

  .cs-subtitle {
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-muted);
    margin: 0 0 24px;
    max-width: 56ch;
  }

  .cs-hero {
    margin-top: 32px;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--color-line);
  }

  .cs-body {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-ink);
  }

  /* Heading anchor styles for rehype-autolink-headings (D-04) */
  .cs-body :global(.heading-anchor) {
    opacity: 0;
    color: var(--color-accent);
    text-decoration: none;
    margin-right: 4px;
    transition: opacity var(--motion-duration-fast) var(--motion-ease-out);
  }

  .cs-body :global(h2:hover .heading-anchor),
  .cs-body :global(h3:hover .heading-anchor),
  .cs-body :global(.heading-anchor:focus-visible) {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-body :global(.heading-anchor) { transition: none; }
  }

  /* Prose heading sizes — engineer-classic: sharper, mono-flavored hairline rule. */
  .cs-body :global(h2) {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 64px 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-line);
  }
  .cs-body :global(h2:first-child) { margin-top: 0; }

  .cs-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-ink);
    margin: 40px 0 12px;
  }

  /* Inline accents in prose */
  .cs-body :global(strong) { color: var(--color-ink); font-weight: 700; }
  .cs-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    transition: border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .cs-body :global(a:hover) { border-bottom-color: var(--color-accent); }
  .cs-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    color: var(--color-accent);
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid var(--color-line);
  }
  .cs-body :global(p) { margin: 0 0 20px; }

  /* Lede paragraph (engineer-classic): hairline accent rail + slightly larger type. */
  .cs-body :global(.cs-lede) {
    font-size: clamp(18px, 1.9vw, 20px);
    line-height: 1.65;
    color: var(--color-ink);
    border-left: 3px solid var(--color-accent);
    padding-left: 20px;
    margin: 0 0 36px;
    max-width: 64ch;
  }
  .cs-body :global(.cs-lede strong) {
    color: var(--color-accent);
    font-weight: 700;
  }
  .cs-body :global(ul),
  .cs-body :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }
  .cs-body :global(li) { margin-bottom: 8px; }
</style>
