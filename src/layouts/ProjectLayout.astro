---
// src/layouts/ProjectLayout.astro
// Project detail layout (D-08 MDX components, no JSON-LD per D-18, no prev/next per D-05,
// no reading time per D-11). Hero image full-width at aspect-ratio 21/9 (UI-SPEC).

import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import TagChip from "../components/ui/TagChip.astro";
import Callout from "../components/mdx/Callout.astro";
import Figure from "../components/mdx/Figure.astro";
import Aside from "../components/mdx/Aside.astro";
import ContactCTAStrip from "../components/cta/ContactCTAStrip.astro";

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const siteUrl = "https://shivanshchoudhary.info";
const pageUrl = new URL(`/projects/${entry.id}/`, siteUrl).toString();

// OG image: heroImage if present, else og-default (D-19)
const ogImage = entry.data.heroImage
  ? new URL(entry.data.heroImage.src, siteUrl).toString()
  : new URL("/og-default.png", siteUrl).toString();
// No JSON-LD for projects (D-18: only blog and case-studies emit Article)
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  canonical={pageUrl}
  ogImage={ogImage}
>
  <article class="project-detail">
    {/* Header: mono eyebrow → display title (UI-SPEC) */}
    <div class="detail-header-text">
      <p class="detail-eyebrow">
        <a href="/projects/" class="detail-eyebrow-link">/projects</a>
      </p>
      <h1 class="detail-title">{entry.data.title}</h1>
      <p class="detail-summary">{entry.data.summary}</p>
    </div>

    {entry.data.heroImage && (
      <div class="detail-hero">
        <Image
          src={entry.data.heroImage}
          alt={entry.data.title}
          loading="eager"
          widths={[800, 1200, 1600]}
          sizes="100vw"
          class="hero-image"
        />
      </div>
    )}

    <!-- Metadata below hero: tags + repo/demo links -->
    <div class="detail-meta">
      <div class="detail-tags">
        {entry.data.tags.map((tag) => (
          <TagChip tag={tag} collection="projects" />
        ))}
      </div>
      <div class="detail-links">
        {entry.data.repoUrl && (
          <a
            href={entry.data.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View source on GitHub"
            class="detail-link"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            View source
          </a>
        )}
        {entry.data.demoUrl && (
          <a
            href={entry.data.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View live demo"
            class="detail-link"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 2H3a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1V9.5h-1.5V13H3V3h3.5V1.5L6.5 2zM9 1.5V3h3.44l-5.72 5.72 1.06 1.06L13.5 4.06V7.5H15V1.5H9z"/>
            </svg>
            Live demo
          </a>
        )}
      </div>
    </div>

    <!-- Prose body in 65ch column — MDX components registered per-page (D-08, Research Pattern 7) -->
    <div class="detail-body">
      <Content components={{ Callout, Figure, Aside }} />
    </div>
    <ContactCTAStrip />
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding: clamp(56px, 9vw, 96px) 0 clamp(64px, 9vw, 96px);
  }

  .detail-header-text {
    max-width: min(72ch, 100% - 2rem);
    margin: 0 auto 32px;
    padding: 0 1rem;
  }

  .detail-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin: 0 0 16px;
  }
  .detail-eyebrow-link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--motion-duration-base) var(--motion-ease-out);
  }
  .detail-eyebrow-link:hover { color: var(--color-ink); }
  .detail-eyebrow-link::before { content: "← "; }

  .detail-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 16px;
  }

  .detail-summary {
    font-size: clamp(17px, 2.2vw, 20px);
    font-weight: 500;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
    max-width: 56ch;
  }

  .detail-hero {
    width: 100%;
    margin-bottom: 32px;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-line);
  }

  .detail-meta {
    max-width: min(72ch, 100% - 2rem);
    margin: 0 auto 40px;
    padding: 0 1rem 24px;
    border-bottom: 1px solid var(--color-line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  .detail-tags { display: flex; flex-wrap: wrap; gap: 4px; }

  .detail-links {
    display: flex;
    gap: 16px;
    margin-left: auto;
  }

  .detail-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color var(--motion-duration-fast) var(--motion-ease-out);
  }

  .detail-link:hover { color: var(--color-accent); }

  @media (prefers-reduced-motion: reduce) {
    .detail-link { transition: none; }
  }

  .detail-body {
    max-width: min(72ch, 100% - 2rem);
    margin: 0 auto;
    padding: 0 1rem;
    font-size: 17px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-ink);
  }

  /* Heading anchors (D-04) */
  .detail-body :global(.heading-anchor) {
    opacity: 0;
    color: var(--color-accent);
    text-decoration: none;
    margin-right: 4px;
    transition: opacity var(--motion-duration-fast) var(--motion-ease-out);
  }

  .detail-body :global(h2:hover .heading-anchor),
  .detail-body :global(h3:hover .heading-anchor),
  .detail-body :global(.heading-anchor:focus-visible) {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .detail-body :global(.heading-anchor) { transition: none; }
  }

  /* Prose heading sizes — engineer-classic */
  .detail-body :global(h2) {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 64px 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-line);
  }
  .detail-body :global(h2:first-child) { margin-top: 0; }

  .detail-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-ink);
    margin: 40px 0 12px;
  }

  /* Inline accents */
  .detail-body :global(p) { margin: 0 0 20px; }
  .detail-body :global(strong) { color: var(--color-ink); font-weight: 700; }
  .detail-body :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    transition: border-color var(--motion-duration-base) var(--motion-ease-out);
  }
  .detail-body :global(a:hover) { border-bottom-color: var(--color-accent); }
  .detail-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    color: var(--color-accent);
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid var(--color-line);
  }
  .detail-body :global(ul),
  .detail-body :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
  }
  .detail-body :global(li) { margin-bottom: 8px; }

  /* Lede paragraph — same pattern as case-study */
  .detail-body :global(.detail-lede) {
    font-size: clamp(18px, 1.9vw, 20px);
    line-height: 1.65;
    color: var(--color-ink);
    border-left: 3px solid var(--color-accent);
    padding-left: 20px;
    margin: 0 0 36px;
    max-width: 64ch;
  }
  .detail-body :global(.detail-lede strong) {
    color: var(--color-accent);
    font-weight: 700;
  }
</style>
