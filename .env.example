# Cloudflare Turnstile — Phase 5 (D-02)
# PUBLIC_ prefix required: Astro exposes this to browser-side code via import.meta.env
# Use test key 1x00000000000000000000AA for local development (always passes)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key: Netlify environment variables only — NEVER commit to repo
# TURNSTILE_SECRET_KEY=<set in Netlify dashboard>
